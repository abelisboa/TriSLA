# TriSLA Portal - .gitignore

# Arquivos de configuração sensíveis
values.yaml
inventory.yaml
*.env
.env*

# Permitir arquivos de exemplo
!values-example.yaml
!inventory-example.yaml
!*-example.*

# Credenciais e secrets
secrets/
*.pem
*.key
*.crt
*.p12
*.pfx

# Logs
*.log
logs/
nohup.out

# Arquivos temporários
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

