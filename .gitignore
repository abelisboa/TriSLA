#################################################
# TRI-SLA PUBLIC REPOSITORY POLICY
# Only apps/, docs/, helm/ allowed
#################################################

# Ignore everything
*

# Allow only:
!apps/
!docs/
!helm/
!README.md
!.gitignore

# Allow contents inside allowed dirs
!apps/**
!docs/**
!helm/**

#################################################
# Explicitly forbidden content
#################################################

# Prompts
prompts/
PROMPTS/
PROMPT_*.md

# Run artifacts
run_*/
sem_*/
snapshot_*/
snapshots/
trisla_avaliacao_*/
trisla_evidencias_*/

# Test results
tests/results/
*.jsonl

# Logs
*.log
*_logs.txt
logs/

# Helm packaged releases
*.tgz

# Virtual environments
venv/
venv_*/
.venv/

# Python cache
__pycache__/
*.pyc

# OS
.DS_Store
Thumbs.db
# Block portal entirely
trisla-portal/
