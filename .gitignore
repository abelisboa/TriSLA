# ==========================================
# TriSLA — Public Repository Clean Rules
# ==========================================

# 🔸 Ignore binários, backups e temporários
*.zip
*.tar.gz
*.log
nohup.out
venv/
__pycache__/
backup*/
*.pid

# 🔸 Ignore arquivos locais e rascunhos
ANALISE_*.md
COMANDOS_*.md
COMANDO_*.txt
Artigo_*
ATUALIZACAO_*
RESUMO_*
RELATORIO_*
REFERENCIAS_*.md
*.pptx
*.pdf
*.tex
*.bib
*.sh.bak*

# 🔸 Ignore pacotes locais de dashboard
trisla-dashboard-local*/
trisla-dashboard-v2*/
trisla-dashboard-v3.0*/
trisla-dashboard-v3.2*/
trisla-dashboard-v3.2.*/
trisla-dashboard-v3.1.*/
trisla-dashboard-*.zip

# 🔸 Ignore diretórios privados
trisla-public/
trisla-portal.bak/
trisla-portal-public/
trisla_dissertacao_completo/
backup_git/
backup/
PROMPTS/
docs_evidencias/
STATE/
WU-*/
data/

# 🔸 Manter somente as pastas oficiais
!/ansible/
!/apps/
!/automation/
!/backend/
!/docs/
!/fabric-network/
!/frontend/
!/grafana-dashboards/
!/helm/
!/monitoring/
!/playbooks/
!/release/
!/scripts/
!/scripts-wsl/
!/src/

# 🔸 Manter arquivos de documentação e controle
!.gitignore
!README.md
!CHANGELOG.md
!LICENSE
