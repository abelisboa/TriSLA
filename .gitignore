# ==========================================
# 🛰️ TriSLA — Public Repository Clean Rules (v3.3.1-pre)
# ==========================================

# 🔸 Build e cache locais
*.zip
*.tar.gz
*.log
nohup.out
*.pid
__pycache__/
venv/
node_modules/
.env*

# 🔸 Arquivos de backup e temporários
backup*/
*.tmp
*.bak
*.sh.bak*

# 🔸 Arquivos de trabalho e rascunhos internos
ANALISE_*.md
COMANDOS_*.md
COMANDO_*.txt
Artigo_*
ATUALIZACAO_*
RESUMO_*
RELATORIO_*
REFERENCIAS_*.md
*.pptx
*.pdf
*.tex
*.bib

# 🔸 Dashboards e pacotes locais
trisla-dashboard-local*/
trisla-dashboard-v2*/
trisla-dashboard-v3.*/
trisla-dashboard-*.zip

# 🔸 Diretórios privados e automação interna
trisla-public/
trisla_dissertacao_completo/
backup_git/
backup/
PROMPTS/
docs_evidencias/
STATE/
WU-*/
data/

# 🔸 Manter apenas pastas oficiais
!/ansible/
!/apps/
!/automation/
!/backend/
!/docs/
!/fabric-network/
!/frontend/
!/grafana-dashboards/
!/helm/
!/monitoring/
!/playbooks/
!/release/
!/scripts/
!/scripts-wsl/
!/src/

# 🔸 Manter documentação e metadados públicos
!.gitignore
!README.md
!CHANGELOG.md
!LICENSE
!VERSION
