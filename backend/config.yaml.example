# TriSLA Dashboard Backend Configuration

server:
  host: "0.0.0.0"
  port: 5000
  debug: false

prometheus:
  url: "http://localhost:9090"

sem_nsmf:
  url: "http://localhost:8000"
  token: ""  # Add your token here if needed

cors:
  allowed_origins:
    - "http://localhost:5173"
    - "http://127.0.0.1:5173"
    - "http://localhost:3000"
    - "http://127.0.0.1:3000"



