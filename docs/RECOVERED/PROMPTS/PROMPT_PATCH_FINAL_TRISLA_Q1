# ============================================================
# FASE 4 — SLA-AGENT CLOSED LOOP (SEM INVENTAR)
# ============================================================

echo "===== FASE 4 — SLA-AGENT ====="

SLA_AGENT_PATH=$(find apps -type d -name "*sla-agent*" | head -n 1)

cat <<'EOF' > $SLA_AGENT_PATH/loop_patch.py
import time

def run_loop(collect, evaluate, act):
    while True:
        data = collect()

        if data.get("prb", 0) > 85:
            decision = evaluate(data)
            act(decision)

        time.sleep(10)
EOF

echo "[OK] Loop estruturado (sem alterar endpoints existentes)"

# ============================================================
# FASE 5 — BUILD & DEPLOY (DIGEST ONLY)
# ============================================================

echo "===== FASE 5 — BUILD E DEPLOY ====="

build_deploy () {
  IMG=$1
  DOCKER=$2
  CTX=$3
  DEP=$4
  CNT=$5

  TS=$(date -u +%Y%m%dT%H%M%SZ)

  podman build --format docker \
    -t ghcr.io/abelisboa/${IMG}:${TS} \
    -f ${DOCKER} ${CTX}

  podman push ghcr.io/abelisboa/${IMG}:${TS}

  DIGEST=$(skopeo inspect --authfile ~/.config/containers/auth.json \
    docker://ghcr.io/abelisboa/${IMG}:${TS} | jq -r .Digest)

  kubectl -n trisla set image deployment/${DEP} \
    ${CNT}=ghcr.io/abelisboa/${IMG}@${DIGEST}

  kubectl -n trisla rollout status deployment/${DEP} --timeout=240s
}

build_deploy "trisla-portal-backend" \
  apps/portal-backend/Dockerfile \
  apps/portal-backend \
  trisla-portal-backend \
  portal-backend

echo "[OK] Deploy concluído"

