cat <<'EOF' > $BACKEND/api/interfaces/i1_routes.py
from fastapi import APIRouter
from apps.decision_engine.src.interfaces.ran_i1 import get_ran_metrics
from apps.decision_engine.src.interfaces.tn_i1 import get_tn_metrics
from apps.decision_engine.src.interfaces.cn_i1 import get_cn_metrics

