echo "===== FASE 2 — NASP TRANSLATION ====="

NASP_FILE="apps/nasp-adapter/src"

cat <<'EOF' > $NASP_FILE/translator_patch.py
def translate_sla_to_domain_actions(sla, decision, telemetry):
    slice_type = sla.get("slice_type")

    return {
        "ran": {
            "policy": "high_priority" if slice_type == "urllc" else "balanced",
            "prb": telemetry.get("prb")
        },
        "tn": {
            "latency": telemetry.get("latency")
        },
        "cn": {
            "cpu": telemetry.get("cpu")
        }
    }
EOF

echo "[OK] Translator formalizado (sem substituir lógica existente)"

