  echo "RAN-I1=$(grep -c 'RAN-I1' "$OUT/analysis/interface_logs_tail.txt" || true)"
  echo "TN-I1=$(grep -c 'TN-I1' "$OUT/analysis/interface_logs_tail.txt" || true)"
  echo "BC-I1=$(grep -c 'BC-I1' "$OUT/analysis/interface_logs_tail.txt" || true)"
} | tee "$OUT/analysis/interface_log_counts.txt"

# =========================================================
# FASE 10 — HEALTH FINAL
# =========================================================

kubectl -n trisla get pods -o wide | tee "$OUT/analysis/pods_after.txt"

echo "[OK] LOAD_TEST_03 concluído"
echo "Dataset: $OUT/analysis/dataset.csv"
