# =========================================================
# PROMPT_LOAD_TEST_03
# Pressão controlada em M_t — RAN / Transport / Core
# =========================================================

# MISSÃO
# Executar campanha com pressão controlada no estado multidomínio do TriSLA,
# mantendo código, thresholds, deploy e arquitetura intactos.

# OBJETIVO
# Verificar se a decisão muda quando o estado real da rede M_t degrada,
# preservando Interface Layer ativa em shadow.

# REGRAS ABSOLUTAS
# 1. NÃO alterar código
# 2. NÃO alterar thresholds
# 3. NÃO alterar deploy
# 4. NÃO alterar manifests
# 5. NÃO forçar REJECT artificial
# 6. Apenas aplicar pressão operacional controlada
# 7. Coletar evidências antes/durante/depois
# 8. Abort se API/cluster degradar de forma crítica

export KUBECONFIG=/tmp/kubeconfig.node2
cd /home/porvir5g/gtp5g/trisla || exit 1

OUT="evidencias_load_test_v3_pressure"
mkdir -p "$OUT/raw" "$OUT/analysis" "$OUT/logs"

URL="http://localhost:18001/api/v1/sla/submit"
REPEATS=10
SLEEP=1

# =========================================================
# FASE 0 — SNAPSHOT BASELINE
# =========================================================

kubectl -n trisla get pods -o wide | tee "$OUT/analysis/pods_before.txt"

kubectl -n trisla get deployment trisla-decision-engine \
  -o jsonpath='{.spec.template.spec.containers[0].image}'; echo \
  | tee "$OUT/analysis/decision_engine_image.txt"

kubectl -n trisla exec deployment/trisla-decision-engine -- printenv \
  | egrep 'INTERFACE_LAYER|POLICY|PRB|DECISION_SCORE|ML_' \
  | tee "$OUT/analysis/decision_engine_env.txt"

# =========================================================
# FASE 1 — PORT-FORWARD
# =========================================================

kubectl -n trisla port-forward svc/trisla-portal-backend 18001:8001 \
  > "$OUT/logs/port_forward.log" 2>&1 &

PF_PID=$!
sleep 3

curl -s http://localhost:18001/api/v1/health/global \
  | tee "$OUT/raw/health_before.json"

# =========================================================
# FASE 2 — FUNÇÃO DE REQUEST
# =========================================================

send_request() {
  PHASE=$1
  SLICE=$2
  ID=$3

  case "$SLICE" in
    URLLC)
      LAT=5; REL=99.999; THR=50 ;;
    EMBB)
      LAT=20; REL=99.9; THR=500 ;;
    MMTC)
      LAT=80; REL=95; THR=10 ;;
  esac

  FILE="$OUT/raw/${PHASE}_${SLICE}_${ID}.json"
  STATUS_FILE="$OUT/raw/${PHASE}_${SLICE}_${ID}.status"

  BODY='{
    "template_id": "standard",
    "tenant_id": "lt3-'$PHASE'-'$SLICE'-'$ID'",
    "form_values": {
      "latency": '$LAT',
      "reliability": '$REL',
      "throughput": '$THR'
    }
  }'

  HTTP_CODE=$(curl -s -o "$FILE" -w "%{http_code}" \
    -X POST "$URL" \
    -H "Content-Type: application/json" \
    -d "$BODY")

  echo "$HTTP_CODE" > "$STATUS_FILE"

  if [ "$HTTP_CODE" != "200" ]; then
    echo "[ERRO] $PHASE $SLICE $ID HTTP=$HTTP_CODE"
  else
    DEC=$(jq -r '.decision // "null"' "$FILE")
    SCORE=$(jq -r '.metadata.decision_score // "null"' "$FILE")
    PRB=$(jq -r '.metadata.telemetry_snapshot.ran.prb_utilization // "null"' "$FILE")
    RTT=$(jq -r '.metadata.telemetry_snapshot.transport.rtt_ms // "null"' "$FILE")
    CPU=$(jq -r '.metadata.telemetry_snapshot.core.cpu_utilization // "null"' "$FILE")
    echo "[OK] $PHASE $SLICE $ID decision=$DEC score=$SCORE prb=$PRB rtt=$RTT cpu=$CPU"
  fi

  sleep "$SLEEP"
}

run_phase() {
  PHASE=$1
  for SLICE in URLLC EMBB MMTC; do
    for ID in $(seq 1 $REPEATS); do
      send_request "$PHASE" "$SLICE" "$ID"
    done
  done
}

# =========================================================
# FASE 3 — BASELINE SEM PRESSÃO
# =========================================================

echo "[FASE 3] Baseline"
run_phase "baseline"

# =========================================================
# FASE 4 — PRESSÃO CONTROLADA
# =========================================================

echo "[FASE 4] Iniciando pressão controlada"

# Core CPU pressure leve e reversível dentro do namespace
kubectl -n trisla run trisla-core-pressure \
  --image=busybox:1.36 \
  --restart=Never \
  -- sh -c 'while true; do :; done' \
  > "$OUT/logs/core_pressure_create.log" 2>&1 || true

sleep 10

kubectl -n trisla get pod trisla-core-pressure -o wide \
  | tee "$OUT/analysis/core_pressure_pod.txt"

echo "[FASE 4.1] Campanha sob pressão"
run_phase "pressure"

# =========================================================
# FASE 5 — REMOVER PRESSÃO
# =========================================================

echo "[FASE 5] Removendo pressão"

kubectl -n trisla delete pod trisla-core-pressure \
  --ignore-not-found=true \
  | tee "$OUT/logs/core_pressure_delete.log"

sleep 10

# =========================================================
# FASE 6 — RECOVERY
# =========================================================

echo "[FASE 6] Recovery"
run_phase "recovery"

kill $PF_PID 2>/dev/null

# =========================================================
# FASE 7 — DATASET LIMPO
# =========================================================

cat > "$OUT/analysis/dataset.csv" << 'EOF'
phase,slice,id,http_status,decision,decision_score,decision_band,confidence,nasp_status,bc_status,sla_agent_status,telemetry_complete,dominant_domain,reason_codes,ran_prb,transport_rtt,transport_jitter,core_cpu,core_memory,admission_total_ms,semantic_ms,decision_ms,ml_ms,nasp_ms,blockchain_ms,sla_agent_ms,tx_hash,block_number
EOF

for f in "$OUT"/raw/*.json; do
  base=$(basename "$f" .json)

  case "$base" in
    health_before) continue ;;
  esac

  PHASE=$(echo "$base" | cut -d_ -f1)
  SLICE=$(echo "$base" | cut -d_ -f2)
  ID=$(echo "$base" | cut -d_ -f3)
  STATUS=$(cat "$OUT/raw/${base}.status" 2>/dev/null || echo "NA")

  jq -r \
    --arg phase "$PHASE" \
    --arg slice "$SLICE" \
    --arg id "$ID" \
    --arg http "$STATUS" '
    [
      $phase,
      $slice,
      $id,
      $http,
      (.decision // ""),
      (.metadata.decision_score // ""),
      (.metadata.decision_band // ""),
      (.confidence // .metadata.final_decision_confidence // ""),
      (.metadata.nasp_orchestration_status // ""),
      (.bc_status // ""),
      (.sla_agent_status // ""),
      (.metadata.telemetry_complete // .telemetry_complete // ""),
      (.metadata.dominant_domain // ""),
      ((.metadata.reason_codes // []) | join("|")),
      (.metadata.telemetry_snapshot.ran.prb_utilization // ""),
      (.metadata.telemetry_snapshot.transport.rtt_ms // .metadata.telemetry_snapshot.transport.rtt // ""),
      (.metadata.telemetry_snapshot.transport.jitter_ms // .metadata.telemetry_snapshot.transport.jitter // ""),
      (.metadata.telemetry_snapshot.core.cpu_utilization // .metadata.telemetry_snapshot.core.cpu // ""),
      (.metadata.telemetry_snapshot.core.memory_bytes // .metadata.telemetry_snapshot.core.memory // ""),
      (.metadata.module_latencies_ms.admission_total_ms // .admission_time_total_ms // ""),
      (.metadata.module_latencies_ms.semantic_parsing_ms // .semantic_parsing_latency_ms // ""),
      (.metadata.module_latencies_ms.sem_pipeline_to_decision_ms // .decision_duration_ms // ""),
      (.metadata.module_latencies_ms.ml_nsmf_predict_ms // ""),
      (.metadata.module_latencies_ms.nasp_orchestration_ms // ""),
      (.metadata.module_latencies_ms.blockchain_register_ms // ""),
      (.metadata.module_latencies_ms.sla_agent_ingest_http_ms // ""),
      (.tx_hash // .blockchain_tx_hash // ""),
      (.block_number // "")
    ] | @csv
  ' "$f" >> "$OUT/analysis/dataset.csv"
done

# =========================================================
# FASE 8 — RESUMOS
# =========================================================

python3 - << 'PY'
import pandas as pd
from pathlib import Path

out = Path("evidencias_load_test_v3_pressure/analysis")
df = pd.read_csv(out / "dataset.csv")

df.to_csv(out / "dataset_requests_only.csv", index=False)

decision_summary = df.groupby(["phase", "slice", "decision"]).size().reset_index(name="count")
decision_summary.to_csv(out / "decision_summary.csv", index=False)

score_summary = df.groupby(["phase", "slice"])["decision_score"].agg(
    ["count", "mean", "std", "min", "max"]
).reset_index()
score_summary.to_csv(out / "score_summary.csv", index=False)

telemetry_summary = df.groupby(["phase", "slice"])[
    ["ran_prb", "transport_rtt", "transport_jitter", "core_cpu", "core_memory"]
].agg(["mean", "std", "min", "max"])
telemetry_summary.to_csv(out / "telemetry_summary.csv")

lat_cols = ["admission_total_ms", "decision_ms", "ml_ms", "nasp_ms", "blockchain_ms", "sla_agent_ms"]
latency_summary = df.groupby(["phase", "slice"])[lat_cols].agg(["mean", "std", "min", "max"])
latency_summary.to_csv(out / "latency_summary.csv")

print("=== Decision Summary ===")
print(decision_summary.to_string(index=False))

print("\n=== Score Summary ===")
print(score_summary.to_string(index=False))

print("\n=== Telemetry Summary ===")
print(telemetry_summary.to_string())
PY

