# =========================================================
# PROMPT_IFACE_04_OBSERVABILITY_FIX
# Interface Layer — Fix Observability / Runtime Logs
# =========================================================

# MISSÃO
# Corrigir a observabilidade da Interface Layer para que CN-I1, RAN-I1,
# TN-I1, OBS-I1 e BC-I1 emitam logs visíveis no stdout do pod.

# REGRAS ABSOLUTAS
# 1. NÃO alterar endpoints.
# 2. NÃO alterar payloads.
# 3. NÃO alterar decisão.
# 4. NÃO alterar NASP/BC/SLA-Agent.
# 5. NÃO introduzir gateway.
# 6. NÃO alterar fluxo funcional.
# 7. Apenas corrigir logging/observabilidade.
# 8. Build/deploy somente depois de validação local.
# 9. Deploy sempre por digest remoto GHCR.
# 10. Nunca usar latest/tag em runtime.

export KUBECONFIG=/tmp/kubeconfig.node2
cd /home/porvir5g/gtp5g/trisla || exit 1

OUT="evidencias_interfaces_observability_fix"
mkdir -p "$OUT/analysis"

# FASE 1 — Backup dos ficheiros
cp apps/decision-engine/src/interfaces/base_interface.py \
   "$OUT/analysis/base_interface.py.before"

# FASE 2 — Corrigir logger para stdout
cat > apps/decision-engine/src/interfaces/base_interface.py << 'EOF'
import json
import logging
import sys
from datetime import datetime, timezone

logger = logging.getLogger("trisla.interfaces")
logger.setLevel(logging.INFO)
logger.propagate = True

if not logger.handlers:
    handler = logging.StreamHandler(sys.stdout)
    handler.setLevel(logging.INFO)
    formatter = logging.Formatter("%(message)s")
    handler.setFormatter(formatter)
    logger.addHandler(handler)


def _safe_payload_summary(payload):
    if payload is None:
        return {}

    if isinstance(payload, dict):
        summary = {}
        for key in [
            "tenant_id",
            "request_id",
            "decision",
            "decision_score",
            "bc_status",
            "sla_agent_status",
            "nasp_orchestration_status",
            "telemetry_complete",
            "phase",
            "mode",
        ]:
            if key in payload:
                summary[key] = payload.get(key)
        return summary

    return {"type": type(payload).__name__}


def log_interface(interface_id, payload=None, phase=None, mode=None):
    event = {
        "event": "trisla_interface_invoked",
        "interface_id": interface_id,
        "phase": phase,
        "mode": mode,
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "payload_summary": _safe_payload_summary(payload),
    }

    logger.info("[INTERFACE] " + json.dumps(event, sort_keys=True))
EOF

# FASE 3 — Verificar chamadas existentes
grep -R "log_interface" -n apps/decision-engine/src/interfaces \
  | tee "$OUT/analysis/log_interface_references.txt"

# FASE 4 — Compilar localmente
python3 -m py_compile \
  apps/decision-engine/src/interfaces/base_interface.py \
  apps/decision-engine/src/interfaces/hooks.py \
  apps/decision-engine/src/interfaces/cn_i1.py \
  apps/decision-engine/src/interfaces/obs_i1.py \
  apps/decision-engine/src/interfaces/bc_i1.py \
  apps/decision-engine/src/interfaces/ran_i1.py \
  apps/decision-engine/src/interfaces/tn_i1.py \
  apps/decision-engine/src/engine.py \
  apps/decision-engine/src/service.py

# FASE 5 — Diff controlado
git diff -- apps/decision-engine/src/interfaces/base_interface.py \
  | tee "$OUT/analysis/diff_base_interface.txt"

echo "[OK] Observability fix preparado. NÃO houve deploy ainda."