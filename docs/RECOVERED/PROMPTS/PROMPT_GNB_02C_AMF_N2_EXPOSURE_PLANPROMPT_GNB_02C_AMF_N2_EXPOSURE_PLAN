# =========================================================
# PROMPT_GNB_02C_AMF_N2_EXPOSURE_PLAN
# Plano cirúrgico para expor AMF N2/SCTP 38412
# =========================================================

# REGRAS
# 1. NÃO alterar recursos.
# 2. NÃO reiniciar AMF.
# 3. NÃO iniciar gNB.
# 4. Apenas auditar chart/manifests/configs e gerar plano.
# 5. Propor alternativas com rollback.

export KUBECONFIG=/tmp/kubeconfig.node2
cd /home/porvir5g/gtp5g || exit 1

OUT="trisla/evidencias_gnb_real/n2_exposure_plan_02c"
mkdir -p "$OUT/analysis" "$OUT/config"

AMF_NS="ns-1274485"
AMF_POD="amf-free5gc-amf-amf-0"

echo "[FASE 1] AMF runtime"
kubectl -n "$AMF_NS" get pod "$AMF_POD" -o yaml \
  | tee "$OUT/analysis/amf_pod.yaml"

kubectl -n "$AMF_NS" get svc -o yaml \
  | tee "$OUT/analysis/amf_services.yaml"

kubectl -n "$AMF_NS" get configmap -o yaml \
  | tee "$OUT/analysis/amf_configmaps.yaml"

echo "[FASE 2] Procurar ngap/sctp/38412 nos charts/manifests"
find . -type f \( -name "*.yaml" -o -name "*.yml" -o -name "*.tpl" -o -name "values*.yaml" \) \
  | xargs grep -nEi "amf|ngap|sctp|38412|n2|hostNetwork|nodePort" \
  | tee "$OUT/analysis/repo_n2_references.txt" || true

echo "[FASE 3] Procurar Helm release/values"
helm list -A | tee "$OUT/analysis/helm_releases.txt"

helm get values -n "$AMF_NS" free5gc -a \
  > "$OUT/analysis/free5gc_helm_values.yaml" 2>&1 || true

helm get manifest -n "$AMF_NS" free5gc \
  > "$OUT/analysis/free5gc_helm_manifest.yaml" 2>&1 || true

grep -nEi "amf|ngap|sctp|38412|hostNetwork|nodePort" \
  "$OUT/analysis/free5gc_helm_values.yaml" \
  "$OUT/analysis/free5gc_helm_manifest.yaml" \
  | tee "$OUT/analysis/helm_n2_extract.txt" || true

echo "[FASE 4] Gerar alternativas de exposição N2"

cat > "$OUT/analysis/n2_exposure_options.md" << 'EOF'
# AMF N2/SCTP Exposure Options

## Estado observado
- AMF pod: sem socket SCTP 38412 visível.
- Service atual: não expõe 38412/SCTP.
- hostNetwork: ausente.
- NodePort 38412: ausente.

## Opção A — Corrigir AMF para escutar NGAP/SCTP internamente
Prioridade: obrigatória antes de qualquer exposição externa.
Ação futura:
- validar config AMF `ngapIpList` / bind address;
- garantir processo AMF sobe com NGAP ativo;
- verificar `ss -lS` dentro do pod mostrando 38412.

Risco: médio.
Rollback: restaurar ConfigMap/Helm values anteriores.

## Opção B — Service ClusterIP SCTP para AMF
Usar se gNB rodar dentro do cluster.
Ação futura:
- criar Service separado `amf-n2-sctp` com protocol SCTP, port 38412, targetPort 38412.

Risco: baixo se AMF já escutar 38412.
Rollback: deletar Service.

## Opção C — NodePort SCTP para AMF
Usar se gNB rodar fora do cluster, mas alcançando NodeIP.
Ação futura:
- criar Service NodePort SCTP mapeando 38412.
- validar kube-proxy/SCTP no cluster.

Risco: médio.
Rollback: deletar Service.

## Opção D — hostNetwork para AMF
Usar somente se Service SCTP não funcionar.
Ação futura:
- alterar AMF para hostNetwork;
- bind em NodeIP;
- validar conflito de portas.

Risco: alto.
Rollback: Helm rollback / restaurar deployment.

## Recomendação
1. Primeiro resolver AMF escutando 38412 dentro do pod.
2. Depois preferir Service SCTP.
3. Só usar hostNetwork se Service SCTP falhar.
EOF

cat > "$OUT/config/amf-n2-sctp-service.template.yaml" << 'EOF'
# TEMPLATE — NÃO APLICAR AINDA
apiVersion: v1
kind: Service
metadata:
  name: amf-n2-sctp
  namespace: ns-1274485
spec:
  type: ClusterIP
  selector:
    app.kubernetes.io/name: amf
  ports:
    - name: n2-sctp
      protocol: SCTP
      port: 38412
      targetPort: 38412
EOF

cat > "$OUT/config/amf-n2-sctp-nodeport.template.yaml" << 'EOF'
# TEMPLATE — NÃO APLICAR AINDA
apiVersion: v1
kind: Service
metadata:
  name: amf-n2-sctp-nodeport
  namespace: ns-1274485
spec:
  type: NodePort
  selector:
    app.kubernetes.io/name: amf
  ports:
    - name: n2-sctp
      protocol: SCTP
      port: 38412
      targetPort: 38412
      nodePort: 30412
EOF

echo "[OK] GNB_02C concluído: plano gerado sem alterações."
echo "Evidências em: $OUT"