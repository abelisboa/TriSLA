# =========================================================
# PROMPT_LOAD_TEST_03 — REAL SYSTEM PRESSURE (TRISLA)
# =========================================================
# MISSÃO:
# Introduzir pressão REAL no sistema (CPU + concorrência)
# para gerar variação de telemetria e forçar o Decision Engine
# a produzir decisões diferenciadas (ACCEPT / REJECT).
#
# OBJETIVO FINAL:
# Validar a pergunta de pesquisa e hipótese do TriSLA.
#
# REGRAS:
# - NÃO alterar código do TriSLA
# - NÃO simular métricas
# - USAR apenas carga real
# - EXECUÇÃO auditável e reversível
# =========================================================

cd /home/porvir5g/gtp5g/trisla || exit 1

export EVID_DIR="evidencias_resultados_trisla_v2_load03"
mkdir -p $EVID_DIR/{dataset,analysis,logs,actions}

date -u > $EVID_DIR/analysis/start.txt

# =========================================================
# FASE 0 — PORT-FORWARD CONTROLADO
# =========================================================

if ! lsof -i:18001 >/dev/null 2>&1; then
  kubectl -n trisla port-forward svc/trisla-portal-backend 18001:8001 \
    > $EVID_DIR/logs/portforward.log 2>&1 &
  PF_PID=$!
  echo $PF_PID > $EVID_DIR/analysis/pf_pid.txt
  sleep 3
fi

# =========================================================
# FASE 1 — HEALTH CHECK
# =========================================================

curl -s http://localhost:18001/api/v1/health/global \
  > $EVID_DIR/analysis/health.txt || {
  echo "[ERRO] Backend indisponível"
  exit 1
}

# =========================================================
# FASE 2 — INJETAR PRESSÃO REAL (CPU)
# =========================================================

kubectl -n trisla run trisla-stress \
  --image=progrium/stress \
  --restart=Never \
  -- stress --cpu 4 --timeout 180s \
  > $EVID_DIR/actions/stress_create.txt 2>&1

sleep 5

# =========================================================
# FASE 3 — PAYLOAD AGRESSIVO (HIGH REAL)
# =========================================================

HIGH_PAYLOAD='{
  "template_id": "standard",
  "tenant_id": "lab",
  "form_values": {
    "latency": 5,
    "reliability": 99.999,
    "throughput": 200,
    "device_count": 500
  }
}'

# =========================================================
# FASE 4 — BURST CONCORRENTE
# =========================================================

for i in $(seq 1 40); do
  (
    curl -s -X POST http://localhost:18001/api/v1/sla/submit \
      -H "Content-Type: application/json" \
      -d "$HIGH_PAYLOAD"
    echo ""
  ) >> $EVID_DIR/dataset/raw_high_burst.json &
done

wait

# =========================================================
# FASE 5 — SEGUNDA ONDA (CONTROLE)
# =========================================================

LOW_PAYLOAD='{
  "template_id": "standard",
  "tenant_id": "lab",
  "form_values": {
    "latency": 10,
    "reliability": 99.9,
    "throughput": 100,
    "device_count": 20
  }
}'

for i in $(seq 1 30); do
  curl -s -X POST http://localhost:18001/api/v1/sla/submit \
    -H "Content-Type: application/json" \
    -d "$LOW_PAYLOAD" \
    >> $EVID_DIR/dataset/raw_low_control.json

  echo "" >> $EVID_DIR/dataset/raw_low_control.json
  sleep 1
done

# =========================================================
# FASE 6 — EXTRAÇÃO ROBUSTA
# =========================================================

echo "regime,decision,score,prb,latency,cpu" \
> $EVID_DIR/dataset/dataset.csv

process_file () {
  REGIME=$1
  FILE=$2

  while read -r line; do
    echo "$line" | jq -r --arg regime "$REGIME" '
    try [
      $regime,
      .decision,
      (.metadata.decision_score // 0),
      (.metadata.telemetry_snapshot.ran.prb_utilization // 0),
      (
        .metadata.telemetry_snapshot.transport.latency //
        .metadata.telemetry_snapshot.transport.rtt //
        0
      ),
      (
        .metadata.telemetry_snapshot.core.cpu_utilization //
        .metadata.telemetry_snapshot.core.cpu //
        0
      )
    ] | @csv catch empty' >> $EVID_DIR/dataset/dataset.csv
  done < "$FILE"
}

process_file HIGH $EVID_DIR/dataset/raw_high_burst.json
process_file LOW $EVID_DIR/dataset/raw_low_control.json

# =========================================================
# FASE 7 — LIMPEZA
# =========================================================

kubectl -n trisla delete pod trisla-stress \
  > $EVID_DIR/actions/stress_delete.txt 2>&1

if [ -f $EVID_DIR/analysis/pf_pid.txt ]; then
  kill $(cat $EVID_DIR/analysis/pf_pid.txt) 2>/dev/null
fi

date -u > $EVID_DIR/analysis/end.txt

# =========================================================
# RELATÓRIO
# =========================================================

cat > $EVID_DIR/analysis/report.md <<EOF
# LOAD TEST 03 — REAL SYSTEM PRESSURE

## Execução
- Burst HIGH: 40 requisições concorrentes
- Controle LOW: 30 requisições sequenciais

## Pressão aplicada
- CPU stress (4 cores)
- concorrência real (burst)

## Objetivo
Forçar variação real de telemetria e validar resposta do sistema

## Expectativa
- Score HIGH < Score LOW
- Possível ocorrência de REJECT

## Resultado
Ver dataset.csv

EOF

echo "PROMPT_LOAD_TEST_03 FINALIZADO"