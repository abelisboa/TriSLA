# =========================================================
# PROMPT_TRISLA_11 — DEPLOY DIGEST + PROVA SLICE-AWARE
# =========================================================
# MISSÃO:
# Provar que a correção slice-aware multidomínio está:
# 1. presente no código;
# 2. compilando;
# 3. buildada;
# 4. publicada no GHCR;
# 5. implantada por DIGEST remoto;
# 6. executando no pod;
# 7. produzindo ACCEPT / RENEGOTIATE / REJECT em teste controlado.
#
# REGRAS:
# - NUNCA usar latest/tag no deploy
# - deploy SOMENTE por digest remoto GHCR
# - validar image do deployment == imageID do pod == digest remoto
# - não escrever resultado científico antes desta validação
# =========================================================

set -euo pipefail

cd /home/porvir5g/gtp5g/trisla || exit 1

EVID_DIR="evidencias_trisla_11_runtime_slice_aware"
mkdir -p "$EVID_DIR"/{analysis,logs,build,deploy,tests,rollback}

date -u > "$EVID_DIR/analysis/start.txt"

# =========================================================
# FASE 0 — BACKUP RUNTIME
# =========================================================

kubectl -n trisla get deployment trisla-decision-engine -o yaml \
  > "$EVID_DIR/rollback/decision-engine_before.yaml"

kubectl -n trisla get pods -o wide \
  > "$EVID_DIR/analysis/pods_before.txt"

# =========================================================
# FASE 1 — AUDITAR CÓDIGO LOCAL
# =========================================================

test -f apps/decision-engine/src/trisla09_slice_aware_helpers.py

grep -R "compute_slice_aware_multidomain_decision" -n apps/decision-engine/src \
  > "$EVID_DIR/analysis/helper_usage.txt"

python3 -m py_compile \
  apps/decision-engine/src/engine.py \
  apps/decision-engine/src/trisla09_slice_aware_helpers.py

echo "PY_COMPILE_OK" > "$EVID_DIR/analysis/compile.txt"

# =========================================================
# FASE 2 — TESTE UNITÁRIO LOCAL DO HELPER
# =========================================================

cat > "$EVID_DIR/tests/test_slice_aware.py" <<'PY'
import sys
sys.path.insert(0, "apps/decision-engine/src")

from trisla09_slice_aware_helpers import compute_slice_aware_multidomain_decision

cases = {
    "URLLC_OK": (
        {"slice_type":"URLLC","form_values":{"latency":5,"reliability":99.999,"throughput":50,"device_count":10}},
        {"ran":{"prb_utilization":8},"transport":{"rtt":4,"jitter":1},"core":{"cpu_utilization":20,"memory_utilization":20}},
    ),
    "URLLC_RTT_REJECT": (
        {"slice_type":"URLLC","form_values":{"latency":5,"reliability":99.999,"throughput":50,"device_count":10}},
        {"ran":{"prb_utilization":8},"transport":{"rtt":30,"jitter":1},"core":{"cpu_utilization":20,"memory_utilization":20}},
    ),
    "MMTC_CORE_REJECT": (
        {"slice_type":"mMTC","form_values":{"latency":100,"reliability":99,"throughput":10,"device_count":1000}},
        {"ran":{"prb_utilization":8},"transport":{"rtt":50,"jitter":10},"core":{"cpu_utilization":90,"memory_utilization":88}},
    ),
    "EMBB_PRB_REJECT": (
        {"slice_type":"eMBB","form_values":{"latency":40,"reliability":99.9,"throughput":500,"device_count":50}},
        {"ran":{"prb_utilization":92},"transport":{"rtt":20,"jitter":5},"core":{"cpu_utilization":30,"memory_utilization":30}},
    ),
