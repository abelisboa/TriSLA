PY

python3 "$EVID_DIR/tests/test_slice_aware.py" \
  > "$EVID_DIR/tests/local_helper_results.txt"

grep -q "REJECT" "$EVID_DIR/tests/local_helper_results.txt"

# =========================================================
# FASE 3 — BUILD + PUSH + DIGEST REMOTO GHCR
# =========================================================

TS=$(date -u +%Y%m%dT%H%M%SZ)
IMAGE_TAG="ghcr.io/abelisboa/trisla-decision-engine:${TS}"

echo "$IMAGE_TAG" > "$EVID_DIR/build/image_tag.txt"

podman build --format docker \
  -t "$IMAGE_TAG" \
  -f apps/decision-engine/Dockerfile \
  apps/decision-engine \
  > "$EVID_DIR/build/build.log" 2>&1

podman push "$IMAGE_TAG" \
  > "$EVID_DIR/build/push.log" 2>&1

REMOTE_DIGEST=$(skopeo inspect \
  --authfile ~/.config/containers/auth.json \
  "docker://${IMAGE_TAG}" | jq -r .Digest)

test -n "$REMOTE_DIGEST"
echo "$REMOTE_DIGEST" > "$EVID_DIR/build/remote_digest.txt"

DIGEST_IMAGE="ghcr.io/abelisboa/trisla-decision-engine@${REMOTE_DIGEST}"
echo "$DIGEST_IMAGE" > "$EVID_DIR/build/digest_image.txt"

# =========================================================
# FASE 4 — DEPLOY DIGEST-ONLY
# =========================================================

kubectl -n trisla set image deployment/trisla-decision-engine \
  decision-engine="$DIGEST_IMAGE" \
  > "$EVID_DIR/deploy/set_image.txt"

kubectl -n trisla rollout status deployment/trisla-decision-engine --timeout=240s \
  > "$EVID_DIR/deploy/rollout.txt"

kubectl -n trisla get deployment trisla-decision-engine \
  -o jsonpath='{.spec.template.spec.containers[0].image}' \
  > "$EVID_DIR/deploy/deployment_image.txt"

grep -q "$REMOTE_DIGEST" "$EVID_DIR/deploy/deployment_image.txt"

# =========================================================
# FASE 5 — VALIDAR RUNTIME IMAGEID
# =========================================================

kubectl -n trisla get pods -l app=trisla-decision-engine -o wide \
  > "$EVID_DIR/deploy/pods_after.txt"

kubectl -n trisla get pods -l app=trisla-decision-engine -o json \
  | jq -r '.items[].status.containerStatuses[].imageID' \
  > "$EVID_DIR/deploy/pod_image_ids.txt"

grep -q "$REMOTE_DIGEST" "$EVID_DIR/deploy/pod_image_ids.txt"

# =========================================================
# FASE 6 — PROVAR QUE HELPER EXISTE DENTRO DO POD
# =========================================================

POD=$(kubectl -n trisla get pods -l app=trisla-decision-engine \
  -o jsonpath='{.items[0].metadata.name}')

echo "$POD" > "$EVID_DIR/deploy/runtime_pod.txt"

kubectl -n trisla exec "$POD" -- \
  sh -c 'python - <<PY
import sys
sys.path.insert(0, "/app/src")
from trisla09_slice_aware_helpers import compute_slice_aware_multidomain_decision
print("HELPER_IMPORT_OK")
print(compute_slice_aware_multidomain_decision(
 {"slice_type":"URLLC","form_values":{"latency":5,"reliability":99.999,"throughput":50,"device_count":10}},
 {"ran":{"prb_utilization":8},"transport":{"rtt":30,"jitter":1},"core":{"cpu_utilization":20,"memory_utilization":20}},
 ml_risk=0.1
))
PY' > "$EVID_DIR/tests/runtime_helper_results.txt"

grep -q "HELPER_IMPORT_OK" "$EVID_DIR/tests/runtime_helper_results.txt"
grep -q "REJECT" "$EVID_DIR/tests/runtime_helper_results.txt"

# =========================================================
# FASE 7 — TESTE REAL API /sla/submit
# =========================================================

PORT=18001
PF_CREATED=0

if ! lsof -i :$PORT >/dev/null 2>&1; then
  kubectl -n trisla port-forward svc/trisla-portal-backend $PORT:8001 \
    > "$EVID_DIR/logs/portforward.log" 2>&1 &
  PF_PID=$!
  PF_CREATED=1
  sleep 5
fi

URL="http://localhost:${PORT}/api/v1/sla/submit"
HEALTH="http://localhost:${PORT}/api/v1/health/global"

curl -sf --max-time 10 "$HEALTH" \
  > "$EVID_DIR/analysis/health.txt"

RAW="$EVID_DIR/tests/api_raw.json"
: > "$RAW"
: > "$EVID_DIR/tests/api_http_codes.csv"

run_case() {
  NAME="$1"
  JSON="$2"

  RESP=$(curl -s -w "\nHTTP_CODE:%{http_code}" \
    --max-time 60 \
    -X POST "$URL" \
    -H "Content-Type: application/json" \
    -d "$JSON")

  BODY=$(echo "$RESP" | sed '$d')
  CODE=$(echo "$RESP" | tail -n1 | cut -d: -f2)

  echo "$BODY" >> "$RAW"
  echo "" >> "$RAW"
  echo "$NAME,$CODE" >> "$EVID_DIR/tests/api_http_codes.csv"
}

run_case "URLLC_BASELINE" '{
  "template_id":"urllc",
  "form_values":{"latency":5,"reliability":99.999,"throughput":50,"device_count":10}
}'

run_case "EMBB_BASELINE" '{
  "template_id":"embb",
  "form_values":{"latency":40,"reliability":99.9,"throughput":500,"device_count":50}
}'

run_case "MMTC_BASELINE" '{
  "template_id":"mmtc",
  "form_values":{"latency":100,"reliability":99,"throughput":10,"device_count":1000}
}'

python3 <<'PY' > "$EVID_DIR/tests/api_results.txt"
import json
from pathlib import Path

raw = Path("evidencias_trisla_11_runtime_slice_aware/tests/api_raw.json")
for line in raw.read_text().splitlines():
    if not line.strip():
        continue
    try:
        j = json.loads(line)
        md = j.get("metadata", {}) or {}
        print({
            "decision": j.get("decision"),
            "score": md.get("decision_score"),
            "service_type": j.get("service_type"),
            "slice_md": md.get("slice_aware_multidomain") or md.get("xai", {}).get("slice_aware_multidomain"),
            "reason": j.get("reason_codes") or md.get("reason_codes"),
            "nasp": j.get("nasp_orchestration_status") or md.get("nasp_orchestration_status"),
            "bc": j.get("bc_status") or md.get("bc_status"),
        })
    except Exception as e:
        print({"ERROR": str(e), "raw": line[:120]})
PY

if [ "$PF_CREATED" = "1" ]; then
  kill "$PF_PID" 2>/dev/null || true
fi

# =========================================================
# FASE 8 — RELATÓRIO FINAL
# =========================================================

cat > "$EVID_DIR/analysis/report.md" <<EOF
