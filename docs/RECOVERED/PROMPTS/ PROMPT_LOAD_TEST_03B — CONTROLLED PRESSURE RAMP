# =========================================================
# FASE 4 — FUNÇÃO DE EXECUÇÃO COM CONCORRÊNCIA CONTROLADA
# =========================================================

run_wave () {
  REGIME="$1"
  PAYLOAD="$2"
  TOTAL="$3"
  PARALLEL="$4"
  OUT_DIR="$EVID_DIR/tmp/${REGIME}"

  mkdir -p "$OUT_DIR"

  echo "REGIME=$REGIME TOTAL=$TOTAL PARALLEL=$PARALLEL START=$(date -u)" \
    >> "$EVID_DIR/analysis/waves.txt"

  seq 1 "$TOTAL" | xargs -I{} -P "$PARALLEL" sh -c '
    IDX="$1"
    PAYLOAD="$2"
    OUT="$3"

    HTTP_CODE=$(curl -s --max-time 180 \
      -o "$OUT/part_${IDX}.json" \
      -w "%{http_code}" \
      -X POST http://localhost:18001/api/v1/sla/submit \
      -H "Content-Type: application/json" \
      -d "$PAYLOAD" || echo "000")

    echo "$IDX,$HTTP_CODE" > "$OUT/part_${IDX}.status"
  ' _ {} "$PAYLOAD" "$OUT_DIR"

  cat "$OUT_DIR"/part_*.json > "$EVID_DIR/dataset/raw_${REGIME}.json" 2>/dev/null || true
  cat "$OUT_DIR"/part_*.status > "$EVID_DIR/dataset/status_${REGIME}.csv" 2>/dev/null || true

  echo "REGIME=$REGIME END=$(date -u)" \
    >> "$EVID_DIR/analysis/waves.txt"

  sleep 15
}

# =========================================================
# FASE 5 — RAMP PROGRESSIVO
# =========================================================
# Ordem: controle → moderado → forte → extremo opcional.
# Não colapsar o sistema logo de início.

run_wave LOW "$LOW_PAYLOAD" 20 2
run_wave MEDIUM "$MEDIUM_PAYLOAD" 25 5
run_wave HIGH "$HIGH_PAYLOAD" 30 10
run_wave EXTREME "$EXTREME_PAYLOAD" 20 15

# =========================================================
# FASE 6 — EXTRAÇÃO ROBUSTA COM STATUS SUCCESS/ERROR
# =========================================================

echo "regime,status,http_code,decision,score,prb,latency,cpu,error_detail" \
  > "$EVID_DIR/dataset/dataset.csv"

process_regime () {
  REGIME="$1"
  RAW="$EVID_DIR/dataset/raw_${REGIME}.json"
  STATUS_FILE="$EVID_DIR/dataset/status_${REGIME}.csv"
  TMP_DIR="$EVID_DIR/tmp/${REGIME}"

  for f in "$TMP_DIR"/part_*.json; do
    [ -f "$f" ] || continue

    IDX=$(basename "$f" | sed 's/part_//;s/.json//')
    HTTP_CODE=$(grep "^${IDX}," "$TMP_DIR/part_${IDX}.status" 2>/dev/null | cut -d',' -f2)
    BODY=$(cat "$f")

    echo "$BODY" | jq -r --arg regime "$REGIME" --arg http "$HTTP_CODE" '
      try
      if (.decision? != null) then
        [
          $regime,
          "SUCCESS",
          $http,
          (.decision // ""),
          (.metadata.decision_score // 0),
          (.metadata.telemetry_snapshot.ran.prb_utilization // 0),
          (
            .metadata.telemetry_snapshot.transport.latency //
            .metadata.telemetry_snapshot.transport.rtt //
            0
          ),
          (
            .metadata.telemetry_snapshot.core.cpu_utilization //
            .metadata.telemetry_snapshot.core.cpu //
            0
          ),
          ""
        ] | @csv
      else
        [
          $regime,
          "ERROR",
          $http,
          "",
          "",
          "",
          "",
          "",
          (.detail // .message // .error // "unknown_error")
        ] | @csv
      end
      catch [
        $regime,
        "ERROR",
        $http,
        "",
        "",
        "",
        "",
        "",
        "invalid_json_or_empty_response"
      ] | @csv
    ' >> "$EVID_DIR/dataset/dataset.csv"
  done
}

process_regime LOW
process_regime MEDIUM
process_regime HIGH
process_regime EXTREME

# =========================================================
# FASE 7 — ANÁLISE AUTOMÁTICA
# =========================================================

python3 - <<'PY'
import csv
from collections import defaultdict, Counter
from pathlib import Path

base = Path("evidencias_resultados_trisla_v2_load03b")
dataset = base / "dataset" / "dataset.csv"
summary = base / "analysis" / "summary_by_regime.csv"
report = base / "analysis" / "load03b_summary.txt"

rows = list(csv.DictReader(dataset.open()))

groups = defaultdict(list)
for r in rows:
    groups[r["regime"]].append(r)

with summary.open("w", newline="") as f:
    w = csv.writer(f)
    w.writerow(["regime","total","success","error","accept","reject","renegotiate","mean_score","mean_prb","mean_latency","mean_cpu"])
    for regime, rs in groups.items():
        success = [r for r in rs if r["status"] == "SUCCESS"]
        errors = [r for r in rs if r["status"] == "ERROR"]
        decisions = Counter(r["decision"] for r in success)

        def mean(field):
            vals = []
            for r in success:
                try:
                    vals.append(float(r[field]))
                except:
                    pass
            return sum(vals)/len(vals) if vals else ""

        w.writerow([
            regime,
            len(rs),
            len(success),
            len(errors),
            decisions.get("ACCEPT",0),
            decisions.get("REJECT",0),
            decisions.get("RENEGOTIATE",0),
            mean("score"),
            mean("prb"),
            mean("latency"),
            mean("cpu"),
        ])

with report.open("w") as f:
    f.write("LOAD_TEST_03B SUMMARY\n\n")
    for regime, rs in groups.items():
        success = [r for r in rs if r["status"] == "SUCCESS"]
        errors = [r for r in rs if r["status"] == "ERROR"]
        f.write(f"{regime}: total={len(rs)} success={len(success)} error={len(errors)}\n")
        f.write(f"  decisions={dict(Counter(r['decision'] for r in success))}\n")
        f.write(f"  http={dict(Counter(r['http_code'] for r in rs))}\n\n")
PY

