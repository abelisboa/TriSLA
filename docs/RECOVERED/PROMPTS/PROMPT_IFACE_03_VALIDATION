# =========================================================
# PROMPT_IFACE_03_VALIDATION
# Interface Layer — Validação Sem Regressão
# =========================================================

# MISSÃO
# Validar que a implementação explícita da Interface Layer
# NÃO altera o comportamento do sistema TriSLA.

# OBJETIVO
# Comparar:
# baseline (sem interface)
# vs
# interface layer ativada (shadow)

# e provar equivalência funcional completa.

# =========================================================
# REGRAS INVIOLÁVEIS
# =========================================================
# 1. NÃO alterar código
# 2. NÃO alterar endpoints
# 3. NÃO alterar payloads
# 4. NÃO fazer deploy
# 5. NÃO alterar Kubernetes
# 6. SOMENTE leitura + execução controlada
# 7. Se divergência → parar

# =========================================================
# CONTEXTO
# =========================================================
export KUBECONFIG=/tmp/kubeconfig.node2
cd /home/porvir5g/gtp5g/trisla || exit 1

OUT="evidencias_interfaces_validation"
mkdir -p "$OUT/raw" "$OUT/analysis"

# =========================================================
# FASE 1 — PORT-FORWARD
# =========================================================

kubectl -n trisla port-forward svc/trisla-portal-backend 18001:8001 >/tmp/pf_val.log 2>&1 &
PF_PID=$!
sleep 3

# =========================================================
# FASE 2 — BASELINE EXECUTION
# =========================================================

echo "[FASE 2] Baseline (Interface Layer OFF)"

REQ='{
  "template_id": "standard",
  "tenant_id": "validation",
  "form_values": {
    "latency": 10,
    "reliability": 99.9,
    "throughput": 100
  }
}'

curl -s -X POST http://localhost:18001/api/v1/sla/submit \
  -H "Content-Type: application/json" \
  -d "$REQ" \
  | tee "$OUT/raw/baseline.json"

# =========================================================
# FASE 3 — INTERFACE LAYER (SHADOW)
# =========================================================

echo "[FASE 3] Interface Layer ON (shadow)"

# IMPORTANTE: aqui assume que flags já estão ativas no runtime
# caso não estejam, apenas documentar

curl -s -X POST http://localhost:18001/api/v1/sla/submit \
  -H "Content-Type: application/json" \
  -d "$REQ" \
  | tee "$OUT/raw/interface.json"

# =========================================================
# FASE 4 — EXTRAÇÃO CAMPOS CRÍTICOS
# =========================================================

echo "[FASE 4] Extraindo campos..."

jq '{
  decision,
  decision_score: .metadata.decision_score,
  nasp_status: .metadata.nasp_orchestration_status,
  bc_status,
  sla_agent_status,
  telemetry_complete: .metadata.telemetry_snapshot.telemetry_complete
}' "$OUT/raw/baseline.json" > "$OUT/analysis/baseline_core.json"

jq '{
  decision,
  decision_score: .metadata.decision_score,
  nasp_status: .metadata.nasp_orchestration_status,
  bc_status,
  sla_agent_status,
  telemetry_complete: .metadata.telemetry_snapshot.telemetry_complete
}' "$OUT/raw/interface.json" > "$OUT/analysis/interface_core.json"

# =========================================================
# FASE 5 — COMPARAÇÃO
# =========================================================

echo "[FASE 5] Comparando..."

diff "$OUT/analysis/baseline_core.json" "$OUT/analysis/interface_core.json" \
  | tee "$OUT/analysis/diff.txt"

# =========================================================
# FASE 6 — AVALIAÇÃO AUTOMÁTICA
# =========================================================

if [ -s "$OUT/analysis/diff.txt" ]; then
  echo "[ERRO] Divergência detectada"
  RESULT="FAIL"
else
  echo "[OK] Sem divergência"
  RESULT="PASS"
fi

# =========================================================
# FASE 7 — RELATÓRIO FINAL
# =========================================================

cat > "$OUT/analysis/validation_report.md" << EOF
# Interface Layer Validation Report

## Result
$RESULT

## Criteria

- Decision equality
- Decision score equality
- NASP orchestration status equality
- Blockchain status equality
- SLA-Agent status equality
- Telemetry completeness equality

## Conclusion

If PASS:
The Interface Layer does not introduce any regression and preserves system behavior.

If FAIL:
Differences detected and must be investigated before proceeding.
EOF

# =========================================================
# FASE 8 — CLEANUP
# =========================================================

kill $PF_PID 2>/dev/null

echo "[OK] Validation complete → $OUT"