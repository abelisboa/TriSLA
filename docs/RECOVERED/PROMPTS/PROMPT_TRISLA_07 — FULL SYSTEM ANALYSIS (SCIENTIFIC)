# =========================================================
# FASE 2 — ANÁLISE ESTATÍSTICA (PYTHON)
# =========================================================

python3 << 'EOF'
import pandas as pd

df = pd.read_csv("evidencias_resultados_trisla_07_analysis/analysis/dataset.csv")

# Limpeza básica
df = df.dropna()

# Conversões
for col in ["score","prb","latency","cpu"]:
    df[col] = pd.to_numeric(df[col], errors="coerce")

df = df.dropna()

# Estatísticas por regime
stats = df.groupby("regime").agg({
    "score": ["mean","std"],
    "prb": "mean",
    "latency": "mean",
    "cpu": "mean"
})

stats.to_csv("evidencias_resultados_trisla_07_analysis/analysis/stats_by_regime.csv")

# Correlação
corr = df[["score","prb","latency","cpu"]].corr()
corr.to_csv("evidencias_resultados_trisla_07_analysis/analysis/correlation.csv")

# Distribuição de decisões
decision_counts = df.groupby(["regime","decision"]).size()
decision_counts.to_csv("evidencias_resultados_trisla_07_analysis/analysis/decision_distribution.csv")

EOF

# =========================================================
# FASE 3 — GERAÇÃO DE GRÁFICOS (MATPLOTLIB)
# =========================================================

python3 << 'EOF'
import pandas as pd
import matplotlib.pyplot as plt

df = pd.read_csv("evidencias_resultados_trisla_07_analysis/analysis/dataset.csv")

# Score por regime
df.boxplot(column="score", by="regime")
plt.title("Decision Score by Regime")
plt.suptitle("")
plt.savefig("evidencias_resultados_trisla_07_analysis/figures/score_by_regime.png")
plt.clf()

# PRB vs Score
plt.scatter(df["prb"], df["score"])
plt.xlabel("PRB")
plt.ylabel("Score")
plt.savefig("evidencias_resultados_trisla_07_analysis/figures/prb_vs_score.png")
plt.clf()

# Latência vs Score
plt.scatter(df["latency"], df["score"])
plt.xlabel("RTT")
plt.ylabel("Score")
plt.savefig("evidencias_resultados_trisla_07_analysis/figures/latency_vs_score.png")
plt.clf()

EOF

