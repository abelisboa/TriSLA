# =========================================================
# PROMPT_LOAD_TEST_04B
# Pressão RAN real — validar UE data-plane antes de carga
# =========================================================

# MISSÃO
# Gerar tráfego real via UE/data-plane para tentar elevar PRB observado.
# Se não houver UE com túnel de dados ativo, ABORTAR sem inventar pressão.

# REGRAS
# 1. NÃO alterar código
# 2. NÃO alterar thresholds
# 3. NÃO alterar deploy
# 4. NÃO alterar manifests
# 5. NÃO simular PRB
# 6. Só executar carga se houver UE/data-plane real
# 7. Cleanup obrigatório

export KUBECONFIG=/tmp/kubeconfig.node2
cd /home/porvir5g/gtp5g/trisla || exit 1

OUT="evidencias_load_test_v4b_real_ue_traffic"
mkdir -p "$OUT/raw" "$OUT/analysis" "$OUT/logs"

PROM_URL="http://localhost:19090/api/v1/query?query=avg(trisla_ran_prb_utilization{job="trisla-ran-ue-upf-proxy"})"
API_URL="http://localhost:18001/api/v1/sla/submit"

# =========================================================
# FASE 0 — PORT-FORWARD PROMETHEUS + BACKEND
# =========================================================

kubectl -n monitoring port-forward svc/prometheus-kube-prometheus-prometheus 19090:9090 \
  > "$OUT/logs/pf_prom.log" 2>&1 &
PF_PROM=$!

kubectl -n trisla port-forward svc/trisla-portal-backend 18001:8001 \
  > "$OUT/logs/pf_backend.log" 2>&1 &
PF_API=$!

sleep 3

curl -s "$PROM_URL" | tee "$OUT/raw/prb_before.json"
curl -s http://localhost:18001/api/v1/health/global | tee "$OUT/raw/health_before.json"

# =========================================================
# FASE 1 — AUDITAR UE/DATA-PLANE REAL
# =========================================================

echo "[FASE 1] Procurando pods UE/RAN existentes..."

kubectl get pods -A -o wide \
  | egrep -i 'ue|ueransim|gnb|ran|rantester|free5gc|upf' \
  | tee "$OUT/analysis/ran_related_pods.txt"

UE_POD=$(kubectl get pods -A --no-headers \
  | awk 'tolower($0) ~ /ue|ueransim|rantester/ && $4=="Running" {print $1","$2; exit}')

if [ -z "$UE_POD" ]; then
  echo "[ABORT] Nenhum pod UE/UERANSIM/RANTester Running encontrado" | tee "$OUT/analysis/abort_reason.txt"
  kill $PF_PROM $PF_API 2>/dev/null
  exit 0
fi

UE_NS=$(echo "$UE_POD" | cut -d, -f1)
UE_NAME=$(echo "$UE_POD" | cut -d, -f2)

echo "UE_NS=$UE_NS" | tee "$OUT/analysis/ue_selected.txt"
echo "UE_NAME=$UE_NAME" | tee -a "$OUT/analysis/ue_selected.txt"

kubectl -n "$UE_NS" exec "$UE_NAME" -- ip addr \
  | tee "$OUT/analysis/ue_ip_addr.txt"

if ! grep -E 'uetun|tun' "$OUT/analysis/ue_ip_addr.txt" >/dev/null; then
  echo "[ABORT] UE encontrado, mas sem interface uetun/tun ativa. Não há prova de data-plane." \
    | tee "$OUT/analysis/abort_reason.txt"
  kill $PF_PROM $PF_API 2>/dev/null
  exit 0
fi

# =========================================================
# FASE 2 — DESCOBRIR ALVO DE TRÁFEGO
# =========================================================

echo "[FASE 2] Descobrindo possíveis alvos de tráfego..."

kubectl get pods -A -o wide \
  | egrep -i 'upf|iperf|server|free5gc' \
  | tee "$OUT/analysis/traffic_targets.txt"

TARGET_IP=$(kubectl get pods -A -o wide --no-headers \
  | awk 'tolower($0) ~ /upf/ && $4=="Running" {print $7; exit}')

if [ -z "$TARGET_IP" ]; then
  echo "[ABORT] Nenhum alvo UPF Running encontrado para tráfego UE." \
    | tee "$OUT/analysis/abort_reason.txt"
  kill $PF_PROM $PF_API 2>/dev/null
  exit 0
fi

echo "TARGET_IP=$TARGET_IP" | tee "$OUT/analysis/target_ip.txt"

# =========================================================
# FASE 3 — TESTE DE CONECTIVIDADE UE → TARGET
# =========================================================

echo "[FASE 3] Testando conectividade UE → TARGET..."

kubectl -n "$UE_NS" exec "$UE_NAME" -- sh -c "ping -c 3 $TARGET_IP" \
  | tee "$OUT/analysis/ue_ping_target.txt" || true

if ! grep -i "0% packet loss" "$OUT/analysis/ue_ping_target.txt" >/dev/null; then
  echo "[ABORT] UE não alcança TARGET_IP. Não executar carga falsa." \
    | tee "$OUT/analysis/abort_reason.txt"
  kill $PF_PROM $PF_API 2>/dev/null
  exit 0
fi

# =========================================================
# FASE 4 — INICIAR TRÁFEGO REAL CONTROLADO
# =========================================================

echo "[FASE 4] Iniciando tráfego real controlado via UE..."

kubectl -n "$UE_NS" exec "$UE_NAME" -- sh -c "
  (timeout 180 ping -i 0.05 -s 1200 $TARGET_IP >/tmp/trisla_ue_ping_load.log 2>&1 &)
" || true

sleep 15

curl -s "$PROM_URL" | tee "$OUT/raw/prb_during.json"

# =========================================================
# FASE 5 — SUBMITS SOB TRÁFEGO REAL
# =========================================================

echo "[FASE 5] Executando submits sob tráfego UE..."

for i in $(seq 1 30); do
  curl -s -X POST "$API_URL" \
    -H "Content-Type: application/json" \
    -d '{
      "template_id": "standard",
      "tenant_id": "ran-real-traffic-'$i'",
      "form_values": {
        "latency": 5,
        "reliability": 99.999,
        "throughput": 50
      }
    }' > "$OUT/raw/submit_$i.json"

  jq -r '"[REQ '$i'] decision=\(.decision) score=\(.metadata.decision_score) prb=\(.metadata.telemetry_snapshot.ran.prb_utilization)"' \
    "$OUT/raw/submit_$i.json"

  sleep 1
done

# =========================================================
# FASE 6 — PARAR TRÁFEGO E COLETAR AFTER
# =========================================================

echo "[FASE 6] Encerrando tráfego..."

kubectl -n "$UE_NS" exec "$UE_NAME" -- sh -c "pkill -f 'ping -i 0.05' || true" || true

sleep 10
curl -s "$PROM_URL" | tee "$OUT/raw/prb_after.json"

kubectl -n "$UE_NS" exec "$UE_NAME" -- sh -c "cat /tmp/trisla_ue_ping_load.log 2>/dev/null || true" \
  | tee "$OUT/logs/ue_ping_load.log"

# =========================================================
# FASE 7 — DATASET
# =========================================================

cat > "$OUT/analysis/dataset.csv" << 'EOF'
id,decision,score,prb,rtt,jitter,core_cpu,nasp_status,bc_status,sla_agent_status,telemetry_complete
EOF

for f in "$OUT"/raw/submit_*.json; do
  ID=$(basename "$f" .json | cut -d_ -f2)

  jq -r --arg id "$ID" '
    [
      $id,
      .decision,
      .metadata.decision_score,
      .metadata.telemetry_snapshot.ran.prb_utilization,
      (.metadata.telemetry_snapshot.transport.rtt_ms // .metadata.telemetry_snapshot.transport.rtt),
      (.metadata.telemetry_snapshot.transport.jitter_ms // .metadata.telemetry_snapshot.transport.jitter),
      (.metadata.telemetry_snapshot.core.cpu_utilization // .metadata.telemetry_snapshot.core.cpu),
      .metadata.nasp_orchestration_status,
      .bc_status,
      .sla_agent_status,
      (.metadata.telemetry_complete // .telemetry_complete)
    ] | @csv
  ' "$f" >> "$OUT/analysis/dataset.csv"
done

python3 - << 'PY'
import json
import pandas as pd
from pathlib import Path

out = Path("evidencias_load_test_v4b_real_ue_traffic/analysis")
raw = Path("evidencias_load_test_v4b_real_ue_traffic/raw")

df = pd.read_csv(out / "dataset.csv")
df.describe(include="all").to_csv(out / "dataset_describe.csv")

summary = df.groupby("decision").size().reset_index(name="count")
summary.to_csv(out / "decision_summary.csv", index=False)

score = df["score"].agg(["count","mean","std","min","max"])
prb = df["prb"].agg(["count","mean","std","min","max"])

with open(out / "summary.txt", "w") as f:
    f.write("=== decision_summary ===\n")
    f.write(summary.to_string(index=False))
    f.write("\n\n=== score ===\n")
    f.write(score.to_string())
    f.write("\n\n=== prb ===\n")
    f.write(prb.to_string())
PY

# =========================================================
# FASE 8 — INTERFACE LOGS + CLEANUP
# =========================================================

kubectl -n trisla logs deployment/trisla-decision-engine --tail=2000 \
  | grep INTERFACE \
  | tee "$OUT/analysis/interface_logs_tail.txt"

{
  echo "CN-I1=$(grep -c 'CN-I1' "$OUT/analysis/interface_logs_tail.txt" || true)"
  echo "OBS-I1=$(grep -c 'OBS-I1' "$OUT/analysis/interface_logs_tail.txt" || true)"
  echo "RAN-I1=$(grep -c 'RAN-I1' "$OUT/analysis/interface_logs_tail.txt" || true)"
  echo "TN-I1=$(grep -c 'TN-I1' "$OUT/analysis/interface_logs_tail.txt" || true)"
  echo "BC-I1=$(grep -c 'BC-I1' "$OUT/analysis/interface_logs_tail.txt" || true)"
} | tee "$OUT/analysis/interface_log_counts.txt"

kill $PF_PROM $PF_API 2>/dev/null

echo "[OK] LOAD_TEST_04B concluído"
echo "Dataset: $OUT/analysis/dataset.csv"
echo "Resumo:  $OUT/analysis/summary.txt"