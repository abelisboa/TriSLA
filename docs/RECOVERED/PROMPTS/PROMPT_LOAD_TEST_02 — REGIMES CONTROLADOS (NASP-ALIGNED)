# =========================================================
# PROMPT_LOAD_TEST_02 — REGIMES CONTROLADOS (NASP-ALIGNED)
# =========================================================
# MISSÃO:
# Gerar dataset científico com múltiplos regimes operacionais
# para validar comportamento do Decision Engine do TriSLA.
#
# BASE:
# docs/TRISLA_EXPERIMENTAL_CANONICAL (SSOT)
#
# REGIMES:
# LOW     → condições ideais
# MEDIUM  → degradação moderada
# HIGH    → degradação forte
#
# REGRAS:
# - NÃO alterar arquitetura
# - NÃO usar simulador
# - USAR apenas POST /api/v1/sla/submit
# - USAR telemetria real retornada
# - NÃO assumir nomes de campos (usar fallback seguro)
# =========================================================

cd /home/porvir5g/gtp5g/trisla || exit 1

export EVID_DIR="evidencias_resultados_trisla_v2_load02"
mkdir -p $EVID_DIR/{dataset,analysis,logs}

date -u > $EVID_DIR/analysis/start.txt

# =========================================================
# FASE 0 — PORT-FORWARD CONTROLADO (SE NECESSÁRIO)
# =========================================================

# iniciar apenas se não estiver ativo
lsof -i:18001 >/dev/null 2>&1 || \
kubectl -n trisla port-forward svc/trisla-portal-backend 18001:8001 \
> $EVID_DIR/logs/portforward.log 2>&1 &

PF_PID=$!
sleep 3

# =========================================================
# FASE 1 — HEALTH CHECK
# =========================================================

curl -s http://localhost:18001/api/v1/health/global \
  > $EVID_DIR/analysis/health.txt || {
  echo "[ERRO] Backend indisponível"
  exit 1
}

# =========================================================
# FASE 2 — DEFINIÇÃO DOS REGIMES
# =========================================================

# LOW (baseline)
LOW_PAYLOAD='{
  "template_id": "standard",
  "tenant_id": "lab",
  "form_values": {
    "latency": 10,
    "reliability": 99.9,
    "throughput": 100,
    "device_count": 20
  }
}'

# MEDIUM (carga moderada)
MEDIUM_PAYLOAD='{
  "template_id": "standard",
  "tenant_id": "lab",
  "form_values": {
    "latency": 20,
    "reliability": 99.5,
    "throughput": 80,
    "device_count": 80
  }
}'

# HIGH (carga agressiva)
HIGH_PAYLOAD='{
  "template_id": "standard",
  "tenant_id": "lab",
  "form_values": {
    "latency": 50,
    "reliability": 98.0,
    "throughput": 50,
    "device_count": 150
  }
}'

# =========================================================
# FASE 3 — EXECUÇÃO CONTROLADA
# =========================================================

run_regime () {
  REGIME=$1
  PAYLOAD=$2
  COUNT=$3

  for i in $(seq 1 $COUNT); do
    curl -s -X POST http://localhost:18001/api/v1/sla/submit \
      -H "Content-Type: application/json" \
      -d "$PAYLOAD" \
      >> $EVID_DIR/dataset/raw_${REGIME}.json

    echo "" >> $EVID_DIR/dataset/raw_${REGIME}.json
    sleep 1
  done
}

run_regime LOW "$LOW_PAYLOAD" 30
run_regime MEDIUM "$MEDIUM_PAYLOAD" 30
run_regime HIGH "$HIGH_PAYLOAD" 30

# =========================================================
# FASE 4 — EXTRAÇÃO ROBUSTA (NDJSON SAFE)
# =========================================================

echo "regime,decision,score,prb,latency,cpu" \
> $EVID_DIR/dataset/dataset.csv

process_file () {
  REGIME=$1
  FILE=$2

  while read -r line; do
    echo "$line" | jq -r --arg regime "$REGIME" '
    try [
      $regime,
      .decision,
      (.metadata.decision_score // 0),
      (.metadata.telemetry_snapshot.ran.prb_utilization // 0),
      (
        .metadata.telemetry_snapshot.transport.latency //
        .metadata.telemetry_snapshot.transport.rtt //
        0
      ),
      (
        .metadata.telemetry_snapshot.core.cpu_utilization //
        .metadata.telemetry_snapshot.core.cpu //
        0
      )
    ] | @csv' >> $EVID_DIR/dataset/dataset.csv
  done < "$FILE"
}

process_file LOW $EVID_DIR/dataset/raw_LOW.json
process_file MEDIUM $EVID_DIR/dataset/raw_MEDIUM.json
process_file HIGH $EVID_DIR/dataset/raw_HIGH.json

# =========================================================
# FASE 5 — EXTRAÇÕES PARA ANÁLISE
# =========================================================

cut -d',' -f1 $EVID_DIR/dataset/dataset.csv > $EVID_DIR/analysis/regimes.txt
cut -d',' -f2 $EVID_DIR/dataset/dataset.csv > $EVID_DIR/analysis/decisions.txt
cut -d',' -f3 $EVID_DIR/dataset/dataset.csv > $EVID_DIR/analysis/scores.txt
cut -d',' -f4 $EVID_DIR/dataset/dataset.csv > $EVID_DIR/analysis/prb.txt

# =========================================================
# FASE 6 — RELATÓRIO
# =========================================================

cat > $EVID_DIR/analysis/report.md <<EOF
# LOAD TEST 02 — REGIMES CONTROLADOS

## Execuções
- LOW: 30
- MEDIUM: 30
- HIGH: 30

## Total
90 requisições SLA

## Objetivo
Avaliar comportamento do Decision Engine sob diferentes regimes.

## Regimes
- LOW → baseline
- MEDIUM → degradação moderada
- HIGH → degradação severa

## Métricas coletadas
- Decision (ACCEPT / REJECT / etc)
- Decision Score
- PRB (RAN)
- RTT (transporte)
- CPU (core)

## Observações
- Pipeline real utilizado
- Sem simulador
- Dados coletados diretamente do backend

## Próximo passo
PROMPT_TRISLA_07_RESULTS_AND_ANALYSIS_ALIGNMENT
EOF

# =========================================================
# FASE 7 — LIMPEZA PORT-FORWARD
# =========================================================

kill $PF_PID 2>/dev/null

echo "PROMPT_LOAD_TEST_02 FINALIZADO"