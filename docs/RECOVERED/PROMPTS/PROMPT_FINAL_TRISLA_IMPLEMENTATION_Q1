echo "[FASE 2] Implementando tradução SLA → ações"

mkdir -p apps/nasp-adapter/translator

cat <<'EOF' > apps/nasp-adapter/translator/translator.py
def translate(sla):
    st = sla.get("slice_type")

    if st == "urllc":
        return {
            "ran": {"prb_policy": "high_priority"},
            "tn": {"qos": "low_latency"},
            "cn": {"cpu": "high"}
        }

    if st == "embb":
        return {
            "ran": {"prb_policy": "balanced"},
            "tn": {"qos": "high_throughput"},
            "cn": {"cpu": "medium"}
        }

    return {
        "ran": {"prb_policy": "low"},
        "tn": {"qos": "efficient"},
        "cn": {"cpu": "low"}
    }
EOF

