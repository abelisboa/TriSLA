from fastapi import FastAPI
import requests, os

app = FastAPI()

PROM = os.getenv("PROM_URL", "http://prometheus:9090")

@app.get("/ran-i1/v1/metrics")
def ran_metrics():
    query = "avg(trisla_ran_prb_utilization{job="trisla-ran-ue-upf-proxy"})"
    r = requests.get(f"{PROM}/api/v1/query", params={"query": query})
    val = float(r.json()["data"]["result"][0]["value"][1])
    return {"prb_utilization": val}
EOF

