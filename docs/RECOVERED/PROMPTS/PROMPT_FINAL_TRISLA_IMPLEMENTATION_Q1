# =========================================
# FASE 3 — CLOSED LOOP (SLA-AGENT)
# =========================================

echo "[FASE 3] Ativando closed-loop automático"

cat <<'EOF' > apps/sla-agent/loop.py
import time, requests, os

BACKEND = os.getenv("BACKEND_URL", "http://trisla-portal-backend:8001")

def loop():
    while True:
        try:
            r = requests.get(f"{BACKEND}/api/v1/telemetry/latest")
            data = r.json()

            if data["prb"] > 85:
                requests.post(f"{BACKEND}/api/v1/sla/re-evaluate", json=data)

        except Exception as e:
            print("loop error:", e)

        time.sleep(10)

if __name__ == "__main__":
    loop()
EOF

echo "[OK] Loop contínuo ativado"

