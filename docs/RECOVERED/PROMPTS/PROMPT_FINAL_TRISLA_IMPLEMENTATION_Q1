echo "[FASE 4] Build e deploy GHCR (digest)"

build_push_deploy () {

  IMAGE_NAME=$1
  DOCKERFILE=$2
  CONTEXT=$3
  DEPLOY=$4
  CONTAINER=$5

  TS=$(date -u +%Y%m%dT%H%M%SZ)

  podman build --format docker \
    -t ghcr.io/abelisboa/${IMAGE_NAME}:${TS} \
    -f ${DOCKERFILE} \
    ${CONTEXT}

  podman push ghcr.io/abelisboa/${IMAGE_NAME}:${TS}

  DIGEST=$(skopeo inspect --authfile ~/.config/containers/auth.json \
    docker://ghcr.io/abelisboa/${IMAGE_NAME}:${TS} | jq -r .Digest)

  kubectl -n trisla set image deployment/${DEPLOY} \
    ${CONTAINER}=ghcr.io/abelisboa/${IMAGE_NAME}@${DIGEST}

  kubectl -n trisla rollout status deployment/${DEPLOY} --timeout=240s

  echo "[OK] ${IMAGE_NAME} atualizado -> ${DIGEST}"
}

build_push_deploy "trisla-sla-agent" \
