OUTPUT_DIR="trisla_paper_package/figures_ieee_auto"
LOG_DIR="${OUTPUT_DIR}/logs"

mkdir -p ${OUTPUT_DIR}
mkdir -p ${LOG_DIR}

# =========================================
# FUNÇÃO BASE — VALIDAÇÃO CIENTÍFICA
# =========================================

validate_figure() {
    FIG_NAME=$1
    RESULT_FILE=$2

    echo "Validando ${FIG_NAME}" >> ${LOG_DIR}/validation.log

    python3 << EOF
import pandas as pd
import numpy as np
import sys

df = pd.read_csv("${DATASET_MAIN}")

valid = True
reasons = []

# Critério 1 — existência de correlação relevante
if "prb_utilization" in df.columns:
    corr = df["prb_utilization"].corr(df["decision_score"])
    if abs(corr) < 0.5:
        valid = False
        reasons.append(f"Correlação fraca: {corr}")

# Critério 2 — separação de classes
groups = df.groupby("decision")["decision_score"].mean()
if len(groups.unique()) < 3:
    valid = False
    reasons.append("Classes não separadas")

# Critério 3 — variabilidade
if df["decision_score"].std() < 0.05:
    valid = False
    reasons.append("Baixa variabilidade")

# Resultado
with open("${RESULT_FILE}", "w") as f:
    f.write("VALID=" + str(valid) + "\n")
    for r in reasons:
        f.write(r + "\n")

if not valid:
    sys.exit(1)
EOF

    return $?
}

# =========================================
# LOOP DE GERAÇÃO INTELIGENTE
# =========================================

generate_with_validation() {

    FIG_ID=$1
    SCRIPT_CONTENT=$2

    MAX_ITER=5
    ITER=1

    while [ $ITER -le $MAX_ITER ]; do

        echo "-----------------------------------"
        echo "Figura ${FIG_ID} — tentativa ${ITER}"
        echo "-----------------------------------"

        # Geração da figura
        python3 << EOF
${SCRIPT_CONTENT}
EOF

        # Validação
        validate_figure "${FIG_ID}" "${LOG_DIR}/${FIG_ID}_validation.txt"

        if [ $? -eq 0 ]; then
            echo "Figura ${FIG_ID} VALIDADA com sucesso"
            return 0
        else
            echo "Figura ${FIG_ID} REJEITADA — ajustando..."

            # Estratégias automáticas de correção
            SCRIPT_CONTENT=$(echo "$SCRIPT_CONTENT" | sed 's/sns.scatterplot/sns.regplot/g')
            SCRIPT_CONTENT=$(echo "$SCRIPT_CONTENT" | sed 's/plt.scatter/plt.plot/g')

            ITER=$((ITER+1))
        fi

    done

    echo "Figura ${FIG_ID} FALHOU após ${MAX_ITER} tentativas" >> ${LOG_DIR}/failures.log
}

