# MISSÃO
# Gerar figuras científicas de nível IEEE A/A+ com:
# - curvas
# - regressões
# - inferência estatística
# - leitura científica clara

# E implementar LOOP AUTOMÁTICO:
# gerar → analisar → validar → corrigir → repetir
# até atingir qualidade científica adequada

# =========================================
# REGRAS ABSOLUTAS
# =========================================

# NÃO inventar dados
# NÃO modificar datasets
# NÃO simplificar gráficos
# NÃO usar apenas barras simples
# SEMPRE incluir:
#   - interpretação estatística
#   - consistência visual
#   - separação clara de classes

# Máximo de iterações por figura: 5
# Se não atingir qualidade: gerar relatório de falha

# =========================================
# INPUTS
# =========================================

DATASET_MAIN="evidencias_prompt9_slice_aware/dataset_final_v9.csv"
CORR_DATASET="evidencias_prompt9_slice_aware/multidomain_correlation.csv"
