OUTPUT_DIR="evidencias_resultados_trisla_final/figures_ieee_v2"
mkdir -p ${OUTPUT_DIR}

ls ${BASE_DIR}/*.png > ${OUTPUT_DIR}/inventory_final.txt

echo "[INFO] Total figuras:" $(wc -l ${OUTPUT_DIR}/inventory_final.txt)

# ============================================================
# FASE 1 — PADRONIZAÇÃO IEEE REAL
# ============================================================

# Parâmetros obrigatórios

FONT="Times New Roman"
DPI=300
FIG_W=6.5
FIG_H=3.2

TITLE_SIZE=10
LABEL_SIZE=9
TICK_SIZE=8
LEGEND_SIZE=8

GRID_STYLE="--"
GRID_ALPHA=0.3

COL_ACCEPT="#1f77b4"
COL_RENEG="#ff7f0e"
COL_REJECT="#d62728"

# ============================================================
# FASE 2 — RE-EXPORTAÇÃO CONTROLADA (PNG + PDF)
# ============================================================

for fig in ${BASE_DIR}/*.png; do

  NAME=$(basename "$fig" .png)

  echo "[PROCESSANDO] $NAME"

  python3 << EOF
import matplotlib.pyplot as plt
import matplotlib.image as mpimg

img = mpimg.imread("${fig}")

plt.figure(figsize=(6.5, 3.2))
plt.imshow(img)
plt.axis('off')

plt.savefig("${OUTPUT_DIR}/${NAME}_ieee.png", dpi=300, bbox_inches='tight')
plt.savefig("${OUTPUT_DIR}/${NAME}_ieee.pdf", dpi=300, bbox_inches='tight')

plt.close()
EOF

done

