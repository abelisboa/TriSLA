# =========================================================
# PROMPT_GNB_05 — SINGLE UE ATTACH VALIDATION
# =========================================================

# MISSÃO
# Validar UE único contra gNB real já aceito pelo AMF,
# comprovando Registration, PDU Session e caminho de dados.

# ESTADO ANTERIOR COMPROVADO
# - GNB_04C: NG Setup OK
# - AMF aceitou:
#   - SCTP Accept
#   - Handle NGSetupRequest
#   - Send NG-Setup response
# - PLMN=20893
# - TAC=1
# - SST=1
# - SD=010203

# REGRAS ABSOLUTAS
# - NÃO alterar TriSLA
# - NÃO alterar Decision Engine
# - NÃO alterar thresholds
# - NÃO rodar carga
# - NÃO rodar multi-UE
# - NÃO alterar AMF/SMF/UPF inicialmente
# - Apenas validar UE único
# - Toda evidência deve ser salva

cd /home/porvir5g/gtp5g/trisla || exit 1

export EVID_DIR="evidencias_gnb_real/single_ue_attach_05"
mkdir -p "$EVID_DIR"/{analysis,logs,config,raw}

date -u > "$EVID_DIR/analysis/start_time.txt"
hostname > "$EVID_DIR/analysis/host.txt"

# =========================================================
# FASE 1 — CARREGAR IDENTIDADE 5G VALIDADA
# =========================================================

AMF_NS=$(cat evidencias_gnb_real/n2_fix_03/analysis/amf_namespace.txt)
AMF_SVC_IP=$(kubectl -n "$AMF_NS" get svc amf-n2-sctp -o jsonpath='{.spec.clusterIP}')
HOST_IP=$(ip route get "$AMF_SVC_IP" | awk '{for(i=1;i<=NF;i++) if($i=="src") print $(i+1); exit}')

PLMN="20893"
MCC="208"
MNC="93"
TAC="1"
SST="1"
SD="010203"

echo "$AMF_NS" > "$EVID_DIR/analysis/amf_namespace.txt"
echo "$AMF_SVC_IP" > "$EVID_DIR/analysis/amf_svc_ip.txt"
echo "$HOST_IP" > "$EVID_DIR/analysis/host_ip.txt"

# =========================================================
# FASE 2 — AUDITAR SUBSCRIBERS EXISTENTES
# =========================================================

kubectl get pods -A -o wide | grep -Ei 'mongodb|webui|udr|udm|ausf|nrf|amf|smf|upf' \
  > "$EVID_DIR/analysis/core_pods.txt" || true

kubectl get svc -A -o wide | grep -Ei 'mongodb|webui|udr|udm|ausf|nrf|amf|smf|upf' \
  > "$EVID_DIR/analysis/core_services.txt" || true

# Tentar localizar IMSI/subscriber já usado no ambiente.
grep -RniE 'imsi|supi|20893|010203|permanentKey|opc' /home/porvir5g/gtp5g 2>/dev/null \
  > "$EVID_DIR/analysis/subscriber_references_repo.txt" || true

# =========================================================
# FASE 3 — DEFINIR UE CONFIG PADRÃO FREE5GC/SRSRAN
# =========================================================
# ATENÇÃO:
# Estes valores são defaults comuns em ambientes free5GC/srsRAN.
# Se subscriber real diferente for encontrado em FASE 2,
# substituir IMSI/K/OPC/APN antes de executar.

IMSI="208930000000001"
KEY="8baf473f2f8fd09487cccbd7097c6862"
OPC="8e27b6af0e692e750f32667a3b14605d"
DNN="internet"

cat > "$EVID_DIR/config/ue.yaml" <<EOF
supi: "imsi-${IMSI}"
mcc: "${MCC}"
mnc: "${MNC}"
key: "${KEY}"
op: "00000000000000000000000000000000"
opc: "${OPC}"
amf: "8000"
imei: "356938035643803"
imei_sv: "4370816125816151"

uac_aic:
  mps: false
  mcs: false

uac_acc:
  normal_class: 0
  class_11: false
  class_12: false
  class_13: false
  class_14: false
  class_15: false

sessions:
  - type: "IPv4"
    apn: "${DNN}"
    slice:
      sst: ${SST}
      sd: "${SD}"

configured_nssai:
  - sst: ${SST}
    sd: "${SD}"

default_nssai:
  - sst: ${SST}
    sd: "${SD}"

integrity:
  IA1: true
  IA2: true
  IA3: true

ciphering:
  EA1: true
  EA2: true
  EA3: true
EOF

# =========================================================
# FASE 4 — GERAR CONFIG gNB VALIDADA
# =========================================================

cat > "$EVID_DIR/config/gnb.yaml" <<EOF
cu_cp:
  amf:
    addr: ${AMF_SVC_IP}
    port: 38412
    bind_addr: ${HOST_IP}
    supported_tracking_areas:
      - tac: ${TAC}
        plmn_list:
          - plmn: "${PLMN}"
            tai_slice_support_list:
              - sst: ${SST}
                sd: ${SD}

cell_cfg:
  plmn: "${PLMN}"
  tac: ${TAC}
  pci: 1
EOF

cat "$EVID_DIR/config/gnb.yaml" > "$EVID_DIR/analysis/gnb_config_final.txt"
cat "$EVID_DIR/config/ue.yaml" > "$EVID_DIR/analysis/ue_config_final.txt"

# =========================================================
# FASE 5 — INICIAR gNB REAL CONTROLADO
# =========================================================

docker run --rm \
  --network host \
  -v "$EVID_DIR/config/gnb.yaml:/gnb.yaml" \
  softwareradiosystems/srsran-project \
  gnb -c /gnb.yaml \
  > "$EVID_DIR/logs/gnb.log" 2>&1 &

GNB_PID=$!
echo "$GNB_PID" > "$EVID_DIR/analysis/gnb_pid.txt"

sleep 12

# =========================================================
# FASE 6 — INICIAR UE ÚNICO
# =========================================================
# Observação:
# A imagem/CLI exata do UE pode variar no ambiente.
# Primeiro tentar srsue; se não existir, registrar falha objetiva.

docker run --rm \
  --network host \
  --privileged \
  -v "$EVID_DIR/config/ue.yaml:/ue.yaml" \
  softwareradiosystems/srsran-project \
  srsue /ue.yaml \
  > "$EVID_DIR/logs/ue.log" 2>&1 &

UE_PID=$!
echo "$UE_PID" > "$EVID_DIR/analysis/ue_pid.txt"

sleep 30

# =========================================================
# FASE 7 — COLETAR LOGS CORE COM TIMESTAMP RECENTE
# =========================================================

AMF_POD=$(kubectl -n "$AMF_NS" get pods -o name | grep -i amf | head -n1 | sed 's#pod/##')
SMF_POD=$(kubectl get pods -A -o name | grep -i smf | head -n1 | sed 's#pod/##')
SMF_NS=$(kubectl get pods -A | grep -i smf | awk '{print $1}' | head -n1)
UPF_POD=$(kubectl get pods -A -o name | grep -i upf | head -n1 | sed 's#pod/##')
UPF_NS=$(kubectl get pods -A | grep -i upf | awk '{print $1}' | head -n1)

kubectl -n "$AMF_NS" logs "$AMF_POD" --since=90s > "$EVID_DIR/logs/amf.log" 2>&1 || true
kubectl -n "$SMF_NS" logs "$SMF_POD" --since=90s > "$EVID_DIR/logs/smf.log" 2>&1 || true
kubectl -n "$UPF_NS" logs "$UPF_POD" --since=90s > "$EVID_DIR/logs/upf.log" 2>&1 || true

ip a > "$EVID_DIR/analysis/ip_after_ue.txt" 2>&1 || true
ip route > "$EVID_DIR/analysis/routes_after_ue.txt" 2>&1 || true

# =========================================================
# FASE 8 — EXTRAÇÃO DE EVIDÊNCIAS UE/5GC
# =========================================================

grep -Ei 'registration|registered|authentication|security mode|pdu|session|establish|nas|rrc|attach|tun|ip' \
  "$EVID_DIR/logs/ue.log" > "$EVID_DIR/analysis/ue_attach_extract.txt" || true

grep -Ei 'registration|authentication|security|pdu|session|context|nas|supi|imsi|accept|reject|fail|error' \
  "$EVID_DIR/logs/amf.log" > "$EVID_DIR/analysis/amf_ue_extract.txt" || true

grep -Ei 'pdu|session|n4|pfcp|upf|establish|created|accept|reject|fail|error|dnn|snssai' \
  "$EVID_DIR/logs/smf.log" > "$EVID_DIR/analysis/smf_pdu_extract.txt" || true

grep -Ei 'pfcp|pdr|far|qer|session|n3|gtp|created|error|fail' \
  "$EVID_DIR/logs/upf.log" > "$EVID_DIR/analysis/upf_extract.txt" || true

grep -Ei '==== gNB started ====|ng setup|ue|rrc|connected|pdu|error|fail' \
  "$EVID_DIR/logs/gnb.log" > "$EVID_DIR/analysis/gnb_ue_extract.txt" || true

# =========================================================
# FASE 9 — TESTE DE CAMINHO DE DADOS, SE TUN EXISTIR
# =========================================================

ip link | grep -Ei 'tun|ue|srs|uesim' > "$EVID_DIR/analysis/tun_interfaces.txt" || true

UE_IF=$(ip -o link | awk -F': ' '/tun|ue|srs|uesim/ {print $2; exit}')
echo "$UE_IF" > "$EVID_DIR/analysis/ue_interface.txt"

if [ -n "$UE_IF" ]; then
  ping -I "$UE_IF" -c 5 8.8.8.8 > "$EVID_DIR/analysis/ping_from_ue_if.txt" 2>&1 || true
else
  echo "Nenhuma interface UE/TUN encontrada" > "$EVID_DIR/analysis/ping_from_ue_if.txt"
fi

# =========================================================
# FASE 10 — ENCERRAR PROCESSOS
# =========================================================

kill "$UE_PID" 2>/dev/null || true
kill "$GNB_PID" 2>/dev/null || true

date -u > "$EVID_DIR/analysis/end_time.txt"

# =========================================================
# FASE 11 — RELATÓRIO FINAL
# =========================================================

cat > "$EVID_DIR/RELATORIO_GNB_05.md" <<EOF
# RELATÓRIO GNB_05 — SINGLE UE ATTACH

## Objetivo
Validar UE único sobre gNB real já conectado ao AMF via NGAP.

## Identidade usada
- PLMN: ${PLMN}
- TAC: ${TAC}
- SST: ${SST}
- SD: ${SD}
- IMSI: ${IMSI}
- DNN/APN: ${DNN}

## Evidências gNB
$(cat "$EVID_DIR/analysis/gnb_ue_extract.txt" 2>/dev/null)

## Evidências UE
$(cat "$EVID_DIR/analysis/ue_attach_extract.txt" 2>/dev/null)

## Evidências AMF
$(cat "$EVID_DIR/analysis/amf_ue_extract.txt" 2>/dev/null)

## Evidências SMF
$(cat "$EVID_DIR/analysis/smf_pdu_extract.txt" 2>/dev/null)

## Evidências UPF
$(cat "$EVID_DIR/analysis/upf_extract.txt" 2>/dev/null)

## Interface UE detectada
$(cat "$EVID_DIR/analysis/tun_interfaces.txt" 2>/dev/null)

## Ping via interface UE
$(cat "$EVID_DIR/analysis/ping_from_ue_if.txt" 2>/dev/null)

## Conclusão esperada
SUCESSO se houver:
- Registration Accept
- PDU Session Establishment Accept
- interface UE/TUN criada
- tráfego/ping funcional ou evidência clara de plano de usuário ativo

FALHA se houver:
- authentication failure
- unknown subscriber
- slice/DNN not supported
- PDU session reject
- ausência de interface UE/TUN
EOF

echo "PROMPT_GNB_05 FINALIZADO"