# =========================================================
# PROMPT_GNB_04 — SRSRAN NG SETUP VALIDATION
# =========================================================

# MISSÃO
# Validar conexão real entre srsRAN gNB e AMF via N2 (SCTP/38412)

# REGRAS
# - NÃO rodar carga
# - NÃO rodar múltiplos UEs
# - NÃO alterar TriSLA
# - NÃO alterar NASP
# - Execução isolada e controlada

cd /home/porvir5g/gtp5g/trisla || exit 1

export EVID_DIR="evidencias_gnb_real/ng_setup_04"
mkdir -p "$EVID_DIR"/{logs,analysis}

date -u > "$EVID_DIR/analysis/start_time.txt"

# =========================================================
# FASE 1 — RESOLVER ENDPOINT N2
# =========================================================

AMF_NS=$(cat evidencias_gnb_real/n2_fix_03/analysis/amf_namespace.txt)

AMF_SVC_IP=$(kubectl -n "$AMF_NS" get svc amf-n2-sctp -o jsonpath='{.spec.clusterIP}')
echo "$AMF_SVC_IP" > "$EVID_DIR/analysis/amf_svc_ip.txt"

test -n "$AMF_SVC_IP" || { echo "[ERRO] Service N2 não encontrado"; exit 1; }

# =========================================================
# FASE 2 — CONFIG GNB (TEMP)
# =========================================================

cat > "$EVID_DIR/gnb.yaml" <<EOF
amf:
  addr: ${AMF_SVC_IP}
  port: 38412

gnb:
  id: 0x19B
  tac: 7
  plmn: "20893"
EOF

# =========================================================
# FASE 3 — EXECUTAR SRSRAN GNB
# =========================================================

echo "Iniciando gNB..."

docker run --rm \
  --network host \
  -v "$EVID_DIR/gnb.yaml:/gnb.yaml" \
  srsran/gnb:latest \
  --config /gnb.yaml \
  > "$EVID_DIR/logs/gnb_output.log" 2>&1 &

GNB_PID=$!

sleep 15

# =========================================================
# FASE 4 — COLETAR LOGS AMF
# =========================================================

AMF_POD=$(cat evidencias_gnb_real/n2_fix_03/analysis/amf_pod.txt)

kubectl -n "$AMF_NS" logs "$AMF_POD" --tail=300 \
  > "$EVID_DIR/logs/amf_after_gnb.log"

# =========================================================
# FASE 5 — ANALISAR NG SETUP
# =========================================================

grep -Ei 'ng setup|ngap|sctp|accept|connected' \
  "$EVID_DIR/logs/gnb_output.log" \
  > "$EVID_DIR/analysis/gnb_ngap.txt" || true

grep -Ei 'ng setup|ngap|sctp|accept|connected' \
  "$EVID_DIR/logs/amf_after_gnb.log" \
  > "$EVID_DIR/analysis/amf_ngap.txt" || true

# =========================================================
# FASE 6 — FINALIZAR
# =========================================================

kill $GNB_PID 2>/dev/null || true

# =========================================================
# RELATÓRIO
# =========================================================

cat > "$EVID_DIR/RELATORIO_GNB_04.md" <<EOF
# RELATORIO GNB_04 — NG SETUP

## AMF
Service IP: $(cat $EVID_DIR/analysis/amf_svc_ip.txt)

## Resultado

### gNB
$(cat $EVID_DIR/analysis/gnb_ngap.txt)

### AMF
$(cat $EVID_DIR/analysis/amf_ngap.txt)

## Conclusão

Se aparecer:
- NG Setup Request
- NG Setup Response
- SCTP established

→ SUCESSO (pronto para carga)

Caso contrário:
→ falha de integração N2
EOF

echo "PROMPT_GNB_04 FINALIZADO"