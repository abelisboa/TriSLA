{
  "dashboard": {
    "title": "TriSLA Performance Dashboard",
    "panels": [
      {
        "title": "Jobs Processados por Minuto",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(rq_jobs_finished_total[1m]) * 60"
          }
        ]
      },
      {
        "title": "Latência dos Jobs",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(rq_job_duration_seconds_bucket[5m]))"
          }
        ]
      }
    ]
  }
}
