{
  "dashboard": {
    "id": null,
    "uid": "trisla-slices-management",
    "title": "TriSLA - Gestão de Slices",
    "tags": ["trisla", "slices", "management"],
    "style": "dark",
    "timezone": "browser",
    "refresh": "30s",
    "schemaVersion": 38,
    "version": 1,
    "panels": [
      {
        "id": 1,
        "title": "Slices Ativos",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "count(trisla_slices_active)",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"}
          }
        ]
      },
      {
        "id": 2,
        "title": "Slices por Tipo",
        "type": "barchart",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "sum by (slice_type) (trisla_slices_active{slice_type=~\"URLLC|eMBB|mMTC\"})",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "{{slice_type}}"
          }
        ]
      },
      {
        "id": 3,
        "title": "Slices Criados (24h)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "rate(trisla_slices_created_total[1h])",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "Taxa de Criação"
          }
        ]
      },
      {
        "id": 4,
        "title": "Latência por Tipo de Slice",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "trisla_slice_latency_ms{slice_type=\"URLLC\"}",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "URLLC"
          },
          {
            "expr": "trisla_slice_latency_ms{slice_type=\"eMBB\"}",
            "refId": "B",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "eMBB"
          },
          {
            "expr": "trisla_slice_latency_ms{slice_type=\"mMTC\"}",
            "refId": "C",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "mMTC"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms"
          }
        }
      },
      {
        "id": 5,
        "title": "Bandwidth por Slice",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 20},
        "targets": [
          {
            "expr": "trisla_slice_bandwidth_mbps{slice_type=\"URLLC\"}",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "URLLC"
          },
          {
            "expr": "trisla_slice_bandwidth_mbps{slice_type=\"eMBB\"}",
            "refId": "B",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "eMBB"
          },
          {
            "expr": "trisla_slice_bandwidth_mbps{slice_type=\"mMTC\"}",
            "refId": "C",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "mMTC"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "Mbps"
          }
        }
      },
      {
        "id": 6,
        "title": "Status dos Slices",
        "type": "table",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 28},
        "targets": [
          {
            "expr": "trisla_slices_active",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "format": "table",
            "instant": true
          }
        ],
        "options": {
          "showHeader": true,
          "sortBy": [{"desc": true, "displayName": "Timestamp"}]
        }
      }
    ],
    "time": {
      "from": "now-6h",
      "to": "now"
    }
  }
}




