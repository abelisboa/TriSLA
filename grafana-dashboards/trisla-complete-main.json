{
  "dashboard": {
    "id": null,
    "uid": "trisla-main",
    "title": "TriSLA Portal - Dashboard Principal",
    "tags": ["trisla", "main", "overview"],
    "style": "dark",
    "timezone": "browser",
    "refresh": "30s",
    "schemaVersion": 38,
    "version": 1,
    "links": [
      {
        "type": "link",
        "title": "Criar Slice (LNP)",
        "url": "/d/trisla-slices/create-lnp",
        "icon": "plus",
        "tags": []
      },
      {
        "type": "link",
        "title": "Templates",
        "url": "/d/trisla-slices/templates",
        "icon": "file-copy",
        "tags": []
      },
      {
        "type": "link",
        "title": "Métricas",
        "url": "/d/trisla-metrics/main",
        "icon": "chart-line",
        "tags": []
      },
      {
        "type": "link",
        "title": "Admin",
        "url": "/d/trisla-admin/panel",
        "icon": "cog",
        "tags": []
      }
    ],
    "panels": [
      {
        "id": 1,
        "title": "Status Geral do Sistema",
        "type": "stat",
        "gridPos": {"h": 4, "w": 24, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "up{job=~\"trisla.*\"}",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"}
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "green", "value": 1}
              ]
            },
            "mappings": [
              {
                "options": {
                  "0": {"text": "Sistema Offline"},
                  "1": {"text": "Sistema Online"}
                },
                "type": "value"
              }
            ]
          }
        }
      },
      {
        "id": 2,
        "title": "Componentes TriSLA",
        "type": "stat",
        "gridPos": {"h": 6, "w": 6, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "up{job=\"trisla-portal\",container=\"trisla-api\"}",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "API"
          },
          {
            "expr": "up{job=\"trisla-portal\",container=\"trisla-rq-worker\"}",
            "refId": "B",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "Worker"
          },
          {
            "expr": "up{job=\"decision-engine\"}",
            "refId": "C",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "Decision Engine"
          },
          {
            "expr": "up{job=\"nwdaf\"}",
            "refId": "D",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "NWDAF"
          },
          {
            "expr": "up{job=\"sla-agents\"}",
            "refId": "E",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "SLA Agents"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          },
          "orientation": "horizontal",
          "textMode": "auto",
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto"
        }
      },
      {
        "id": 3,
        "title": "Slices Ativos",
        "type": "stat",
        "gridPos": {"h": 6, "w": 6, "x": 6, "y": 4},
        "targets": [
          {
            "expr": "count(up{job=\"trisla-portal\"} == 1)",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"}
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0}
              ]
            },
            "unit": "short"
          }
        }
      },
      {
        "id": 4,
        "title": "Jobs Processados (Total)",
        "type": "stat",
        "gridPos": {"h": 6, "w": 6, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "trisla_jobs_completed_total",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"}
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "short"
          }
        }
      },
      {
        "id": 5,
        "title": "Taxa de Sucesso",
        "type": "gauge",
        "gridPos": {"h": 6, "w": 6, "x": 18, "y": 4},
        "targets": [
          {
            "expr": "(trisla_jobs_completed_total / (trisla_jobs_completed_total + trisla_jobs_failed_total)) * 100",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"}
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "unit": "percent",
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 70},
                {"color": "green", "value": 90}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Request Rate (Requests/sec)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
        "targets": [
          {
            "expr": "rate(http_requests_total{job=~\"trisla.*\"}[5m])",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "{{job}} {{method}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        }
      },
      {
        "id": 7,
        "title": "Latência de Resposta (p95)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=~\"trisla.*\"}[5m]))",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=~\"trisla.*\"}[5m]))",
            "refId": "B",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "p99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 8,
        "title": "Jobs por Status",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 18},
        "targets": [
          {
            "expr": "trisla_jobs_completed_total",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "Completados"
          },
          {
            "expr": "trisla_jobs_failed_total",
            "refId": "B",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "Falhados"
          },
          {
            "expr": "trisla_jobs_active_total",
            "refId": "C",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "Ativos"
          }
        ]
      },
      {
        "id": 9,
        "title": "Slices por Tipo",
        "type": "barchart",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18},
        "targets": [
          {
            "expr": "sum by (slice_type) (trisla_slices_active{slice_type=~\"URLLC|eMBB|mMTC\"})",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "{{slice_type}}"
          }
        ]
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h"]
    }
  }
}




