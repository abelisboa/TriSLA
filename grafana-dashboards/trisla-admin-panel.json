{
  "dashboard": {
    "id": null,
    "uid": "trisla-admin-panel",
    "title": "TriSLA - Painel Administrativo",
    "tags": ["trisla", "admin", "management"],
    "style": "dark",
    "timezone": "browser",
    "refresh": "30s",
    "schemaVersion": 38,
    "version": 1,
    "panels": [
      {
        "id": 1,
        "title": "Visão Geral do Sistema",
        "type": "stat",
        "gridPos": {"h": 4, "w": 24, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "count(up{job=~\"trisla.*\"} == 1)",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"}
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 3},
                {"color": "green", "value": 5}
              ]
            },
            "mappings": [
              {
                "options": {
                  "0": {"text": "Sistema Offline"},
                  "match": "range",
                  "from": 1,
                  "to": 4,
                  "result": {"text": "Sistema Parcial"},
                  "result": {"text": "Sistema Operacional"}
                },
                "type": "value"
              }
            ]
          }
        }
      },
      {
        "id": 2,
        "title": "Health Check dos Componentes",
        "type": "table",
        "gridPos": {"h": 10, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "up{job=~\"trisla.*\"}",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "format": "table",
            "instant": true
          }
        ],
        "options": {
          "showHeader": true,
          "sortBy": [{"desc": false, "displayName": "Job"}]
        }
      },
      {
        "id": 3,
        "title": "Métricas de Performance",
        "type": "timeseries",
        "gridPos": {"h": 10, "w": 12, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "rate(http_requests_total{job=~\"trisla.*\"}[5m])",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "{{job}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        }
      },
      {
        "id": 4,
        "title": "Uso de Recursos do Cluster",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
        "targets": [
          {
            "expr": "sum(rate(container_cpu_usage_seconds_total{pod=~\"trisla.*\"}[5m])) * 100",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "CPU Total"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent"
          }
        }
      },
      {
        "id": 5,
        "title": "Memória Total",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
        "targets": [
          {
            "expr": "sum(container_memory_usage_bytes{pod=~\"trisla.*\"}) / 1024 / 1024",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "Memória Total (MB)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "MB"
          }
        }
      },
      {
        "id": 6,
        "title": "Alertas e Notificações",
        "type": "table",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 22},
        "targets": [
          {
            "expr": "ALERTS{alertstate=\"firing\"}",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "format": "table",
            "instant": true
          }
        ],
        "options": {
          "showHeader": true
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    }
  }
}




