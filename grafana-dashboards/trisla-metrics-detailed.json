{
  "dashboard": {
    "id": null,
    "uid": "trisla-metrics-detailed",
    "title": "TriSLA - Métricas Detalhadas",
    "tags": ["trisla", "metrics", "monitoring"],
    "style": "dark",
    "timezone": "browser",
    "refresh": "10s",
    "schemaVersion": 38,
    "version": 1,
    "panels": [
      {
        "id": 1,
        "title": "CPU Usage por Componente",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(container_cpu_usage_seconds_total{pod=~\"trisla.*\"}[5m]) * 100",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "{{pod}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 100,
            "min": 0
          }
        }
      },
      {
        "id": 2,
        "title": "Memory Usage por Componente",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "container_memory_usage_bytes{pod=~\"trisla.*\"} / 1024 / 1024",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "{{pod}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "MB"
          }
        }
      },
      {
        "id": 3,
        "title": "Network I/O",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "rate(container_network_receive_bytes_total{pod=~\"trisla.*\"}[5m])",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "RX {{pod}}"
          },
          {
            "expr": "rate(container_network_transmit_bytes_total{pod=~\"trisla.*\"}[5m])",
            "refId": "B",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "TX {{pod}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "Bps"
          }
        }
      },
      {
        "id": 4,
        "title": "Decision Engine - Predições",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "rate(decision_engine_predictions_total[5m])",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "Predições"
          },
          {
            "expr": "rate(decision_engine_decisions_accepted_total[5m])",
            "refId": "B",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "Aceitas"
          },
          {
            "expr": "rate(decision_engine_decisions_rejected_total[5m])",
            "refId": "C",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "Rejeitadas"
          }
        ]
      },
      {
        "id": 5,
        "title": "NWDAF - Análises de Rede",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "nwdaf_network_performance_score",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "Performance Score"
          },
          {
            "expr": "nwdaf_qos_predictions_total",
            "refId": "B",
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "legendFormat": "QoS Predictions"
          }
        ]
      },
      {
        "id": 6,
        "title": "SLA Agents - Status",
        "type": "stat",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "sla_agents_active",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"}
          },
          {
            "expr": "sla_violations_total",
            "refId": "B",
            "datasource": {"type": "prometheus", "uid": "prometheus"}
          },
          {
            "expr": "sla_compliance_rate",
            "refId": "C",
            "datasource": {"type": "prometheus", "uid": "prometheus"}
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 0.7},
                {"color": "green", "value": 0.9}
              ]
            }
          }
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    }
  }
}




