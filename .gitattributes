# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts
*.sh text eol=lf

# Python files
*.py text eol=lf
*.pyc binary

# YAML files
*.yml text eol=lf
*.yaml text eol=lf

# JSON files
*.json text eol=lf

# Markdown files
*.md text eol=lf

# Docker files
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Configuration files
*.conf text eol=lf
*.config text eol=lf

# Git attributes
.gitattributes text eol=lf
.gitignore text eol=lf

# Binary files
*.zip binary
*.tar.gz binary
*.tgz binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary



